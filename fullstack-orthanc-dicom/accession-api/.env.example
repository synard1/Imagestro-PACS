# Accession API Configuration
# Copy this file to .env and modify values as needed

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/accession_db

# Server Configuration
PORT=3000
TIMEZONE=Asia/Jakarta
DEFAULT_FACILITY_CODE=001

# SATUSEHAT Configuration
ISSUER_BASE_URL=http://sys-ids.kemkes.go.id/acsn

# MWL Writer Configuration
MWL_WRITER_URL=http://localhost:8080

# ===== VALIDATION FEATURE TOGGLES =====
# Set to "false" to disable specific validations
ENABLE_IHS_VALIDATION=true
ENABLE_NIK_VALIDATION=true
ENABLE_BIRTHDATE_VALIDATION=true
ENABLE_MRN_VALIDATION=true
ENABLE_SEX_VALIDATION=true

# ===== REQUIRED FIELD TOGGLES =====
# Set to "true" to make fields mandatory
MRN_REQUIRED=false

# ===== VALIDATION PATTERNS =====
# Regular expressions for field validation
NIK_PATTERN=^\d{16}$
IHS_PATTERN=^P\\d{11}$
BIRTHDATE_PATTERN=^\\d{4}-\\d{2}-\\d{2}$
MRN_PATTERN=^[a-zA-Z0-9\\-_]+$

# ===== VALID VALUES =====
# Comma-separated lists of valid values
VALID_MODALITIES=CT,MR,CR,DX,US,XA,RF,MG,NM,PT
VALID_SEX_VALUES=male,female,other,unknown

# ===== LENGTH CONSTRAINTS =====
MRN_MIN_LENGTH=1
MRN_MAX_LENGTH=50

# ===== FORMATTING =====
SEQUENCE_PADDING=6

# ===== DEFAULT VALUES =====
DEFAULT_STATION_AET=ORTHANC
DEFAULT_ACCESSION_STATUS=issued

# ===== FACILITY CONFIGURATION =====
# Name of the healthcare facility
FACILITY_NAME=RS ABC Healthcare

# ===== RESPONSE CONFIGURATION =====
# Set to "false" to exclude issuer from API response (default: true)
INCLUDE_ISSUER_IN_RESPONSE=true

# ===== ERROR MESSAGES =====
# Customize error messages (optional)
ERROR_PATIENT_REQUIRED=Field 'patient' wajib diisi sesuai standar SATUSEHAT
ERROR_NIK_REQUIRED=Field 'patient.id' (NIK) wajib diisi dan tidak boleh kosong
ERROR_NIK_INVALID=NIK harus berupa 16 digit angka
ERROR_NAME_REQUIRED=Field 'patient.name' wajib diisi dan tidak boleh kosong
ERROR_IHS_REQUIRED=Field 'patient.ihs_number' wajib diisi sesuai standar SATUSEHAT
ERROR_IHS_INVALID=IHS Number harus berformat P diikuti 11 digit angka (contoh: P02478375538)
ERROR_BIRTHDATE_INVALID=Field 'birthDate' harus dalam format YYYY-MM-DD (contoh: 1990-01-15)
ERROR_BIRTHDATE_FUTURE=Tanggal lahir tidak boleh di masa depan
ERROR_MRN_INVALID=Medical Record Number hanya boleh berisi huruf, angka, tanda hubung (-), dan underscore (_)
ERROR_MRN_LENGTH=Medical Record Number harus antara {min}-{max} karakter
ERROR_SEX_INVALID=Sex harus salah satu dari: {validValues}
ERROR_MODALITY_REQUIRED=Field 'modality' wajib diisi (contoh: CT, MR, CR, DX, US)
ERROR_MODALITY_INVALID=Modality harus salah satu dari: {validModalities}
ERROR_SCHEDULED_AT_INVALID=Field 'scheduled_at' harus dalam format ISO 8601 (contoh: 2024-01-20T10:30:00Z)