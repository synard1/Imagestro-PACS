# Orthanc DICOM Server Environment Configuration
# Copy this file to .env and update the values

# Satusehat Kemkes Variable
ORG_ID=replace_with_actual_value
CLIENT_ID=replace_with_actual_value
CLIENT_SECRET=replace_with_actual_value
SATUSEHAT_URL=https://api-satusehat-stg.dto.kemkes.go.id
DICOM_CONN_PORT=11112
DICOM_API_PORT=8280

# Database Configuration
POSTGRES_DB=orthanc
POSTGRES_USER=orthanc
POSTGRES_PASSWORD=orthanc_secure_password_change_me

# S3 Backup Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-orthanc-backups-bucket
BACKUP_RETENTION_DAYS=30

# Network Configuration
HTTP_PORT=8042
DICOM_PORT=4242
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443
HAPROXY_STATS_PORT=8404

# Security Configuration
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc_change_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123_change_me

# Monitoring Configuration (Optional)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin123_change_me

# Storage Configuration
ORTHANC_STORAGE_PATH=./data/orthanc
POSTGRES_DATA_PATH=./data/postgres
BACKUP_PATH=./backups

# Performance Tuning
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAX_CONNECTIONS=200

# Logging
LOG_LEVEL=info
LOG_PATH=./logs

# SSL Configuration
SSL_CERT_PATH=./ssl/orthanc.crt
SSL_KEY_PATH=./ssl/orthanc.key
SSL_PEM_PATH=./ssl/orthanc.pem

# Backup Schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
CLEANUP_SCHEDULE=0 3 * * 0 # Weekly on Sunday at 3 AM

# Development/Production Mode
NODE_ENV=production
DEBUG=false

# ============================================================================
# Tenant User Seeding Configuration
# ============================================================================

# Webhook URL for the tenant-seeding-worker (Cloudflare Worker)
# When a new tenant is created, a Tenant_Created_Event is sent to this URL
# Leave empty to disable automatic user seeding
TENANT_SEED_WEBHOOK_URL=

# Shared secret for authenticating webhook requests to the seeding worker
# Must match the GATEWAY_SHARED_SECRET configured in the tenant-seeding-worker
GATEWAY_SHARED_SECRET=
