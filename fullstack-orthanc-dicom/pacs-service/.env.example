
# API Configuration
API_TITLE="PACS RIS Service"
API_VERSION="1.0.0"
API_PREFIX="/pacs"
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://dicom:dicompassword@localhost:5432/worklist_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=worklist_db
DB_USER=dicom
DB_PASSWORD=dicompassword

# Orthanc Configuration
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc

# SatuSehat Configuration
SATUSEHAT_GATEWAY_URL=http://localhost:8888
SATUSEHAT_INTEGRATOR_URL=http://satusehat-integrator:8081
ACCESSION_SYSTEM_BASE=http://sys-ids.kemkes.go.id/acsn
DICOM_ROUTER_HOST=localhost
DICOM_ROUTER_PORT=11112

# Security
SECRET_KEY=dev_secret_key_change_in_production
JWT_SECRET=dev_jwt_secret_change_in_production
ALLOWED_ROLES=superadmin,developer,radiologist,technologist

# Feature Flags
PACS_ENABLED=True
REPORTS_ENABLED=True
AUTO_LINK_ORDERS=True

# AI / LLM Configuration
# Options: mock, gemini, openai
AI_PROVIDER=mock
# Required if AI_PROVIDER is gemini or openai
GEMINI_API_KEY=
AI_MODEL_NAME=gemini-pro
# Optional: Override base URL for proxies or LocalAI/Ollama
AI_API_BASE_URL=

# Monitoring
ENABLE_METRICS=True
ENABLE_DOCS=True
