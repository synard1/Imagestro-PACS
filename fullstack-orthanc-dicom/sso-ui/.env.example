# SSO Web UI Environment Variables

# Application
VITE_APP_NAME=SSO Web UI
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Single Sign-On Web UI for DICOM Healthcare System

# API Endpoints
VITE_API_BASE_URL=http://localhost:8080
VITE_AUTH_SERVICE_URL=http://localhost:8081
VITE_MWL_SERVICE_URL=http://localhost:8095
VITE_ORTHANC_URL=http://localhost:8042
VITE_ORDERS_SERVICE_URL=http://localhost:8097

# Authentication
VITE_JWT_SECRET=your-jwt-secret-key-here
VITE_JWT_EXPIRES_IN=24h
VITE_REFRESH_TOKEN_EXPIRES_IN=7d
VITE_SESSION_TIMEOUT=30m

# Security
VITE_ENABLE_CSRF_PROTECTION=true
VITE_ENABLE_XSS_PROTECTION=true
VITE_ENABLE_CONTENT_SECURITY_POLICY=true
VITE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Features
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_AUDIT_LOGGING=true
VITE_ENABLE_2FA=false
VITE_ENABLE_REMEMBER_ME=true

# UI Configuration
VITE_DEFAULT_THEME=light
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_TIMEZONE=UTC
VITE_ITEMS_PER_PAGE=20
VITE_MAX_FILE_UPLOAD_SIZE=10485760

# Development
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true
VITE_LOG_LEVEL=info

# Production
VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=