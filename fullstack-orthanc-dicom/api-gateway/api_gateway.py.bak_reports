@app.route('/auth/audit/logs', methods=['GET'])
@require_auth()
def auth_audit_logs_proxy():
    """
    Proxy untuk membaca auth_audit_log dari auth-service.

    Security:
    - Hanya untuk operator dengan hak tinggi:
        - SUPERADMIN / DEVELOPER / '*' / 'rbac:manage'
        - atau permission 'system:logs'
    - Filter & pagination dilakukan oleh auth-service, gateway menambahkan guard ekstra.
    """
    user = request.current_user or {}
    perms = user.get("permissions") or []

    allowed = is_superadmin_or_dev(user) or ("system:logs" in perms) or ("rbac:manage" in perms)
    if not allowed:
        logger.warning(
            f"Auth audit logs access denied for user={user.get('username')} "
            f"perms={perms}"
        )
        return jsonify({
            "status": "error",
            "message": "Insufficient privilege to view auth audit logs"
        }), 403

    # Teruskan query params apa adanya; auth-service akan handle filter/sort/pagination.
    return proxy_request(AUTH_SERVICE_URL, 'auth/audit/logs', 'GET', params=request.args)

