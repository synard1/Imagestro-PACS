# ============================================================================
# PATIENT MASTER DATA ROUTES
# ============================================================================

@app.route('/patients/<path:path>', methods=['GET', 'POST', 'PUT', 'DELETE'])
@require_auth()
def patients_proxy(path):
    """Proxy patient master data requests with method-specific permissions"""
    user = request.current_user
    user_perms = user.get('permissions', []) or []

    method_required = {
        'GET': ['patient:read', '*'],
        'POST': ['patient:create', '*'],
        'PUT': ['patient:update', '*'],
        'DELETE': ['patient:delete', '*']
    }
    required = method_required.get(request.method, ['patient:read', '*'])

    # Gunakan check_permission agar wildcard seperti 'patient:*' ikut dikenali
    if not check_permission(user_perms, required):
        logger.warning(
            f"Permission denied for {user.get('username')} on {request.method} /patients/{path}. "
            f"Required: {required}, Has: {user_perms}"
        )
        return jsonify({
            "status": "error",
            "message": "Permission denied",
            "required": required,
            "user_permissions": user_perms
        }), 403

    try:
        response = proxy_request(
            MASTER_DATA_SERVICE_URL,
            f'patients/{path}',
            request.method,
            data=request.get_json(silent=True),
            params=request.args
        )
        return response
    except Exception as e:
        logger.error(f"Patient proxy error: {str(e)}")
        return jsonify({"status": "error", "message": "Failed to proxy request"}), 503

@app.route('/patients/search', methods=['GET'])
@require_auth(['patient:search', '*'])
def patients_search():
    """Search patients - requires patient:search permission"""
    try:
        response = proxy_request(MASTER_DATA_SERVICE_URL, 'patients/search', 'GET', params=request.args)
        return response
    except Exception as e:
        logger.error(f"Patient search error: {str(e)}")
        return jsonify({"status": "error", "message": "Failed to search patients"}), 503

