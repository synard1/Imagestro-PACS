"""
API Gateway - Centralized Authentication & Routing
SECURED VERSION dengan akses Orthanc Web UI dan RBAC Support

Routes requests to appropriate services with JWT validation
Version: 2.2.0 - Production Ready with Enhanced RBAC Support
"""

import os
