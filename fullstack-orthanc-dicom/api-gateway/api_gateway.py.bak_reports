ENABLE_SIMRS_BRIDGE = os.getenv('ENABLE_SIMRS_BRIDGE', 'true').lower() == 'true'

def get_client_ip(req: request) -> str:
    """
    Determine real client IP for forwarding/audit:
    - Use X-Forwarded-For if already set (keep existing chain, append if needed)
    - Else use X-Real-IP
    - Else use req.remote_addr
    """
    try:
        # If behind another proxy/reverse-proxy, it might have set X-Forwarded-For
        xff = req.headers.get("X-Forwarded-For", "").strip()
        if xff:
            # Take first IP in chain as original client
            first_ip = xff.split(",")[0].strip()
            if first_ip:
                return first_ip

        x_real = req.headers.get("X-Real-IP", "").strip()
        if x_real:
            return x_real

        return req.remote_addr or ""
    except Exception:
        return req.remote_addr or ""


def validate_token(token):
    """Validate JWT token"""
    try:
        payload = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGORITHM], leeway=120)
        return payload
    except jwt.ExpiredSignatureError:
        logger.warning("JWT expired during validation")
        return None
    except jwt.InvalidTokenError as e:
        logger.warning(f"JWT invalid during validation: {str(e)}")
        return None


def is_superadmin_or_dev(user: dict) -> bool:
    """
    Determine if user is allowed to manage or view highly sensitive RBAC data.

    Rules (lebih ketat):
    - Memiliki '*' di permissions (global superadmin), ATAU
    - Memiliki role 'superadmin' (case-insensitive), ATAU
    - Memiliki role 'developer' (case-insensitive).

    Catatan:
    - 'system:admin' TIDAK lagi otomatis dianggap superadmin penuh.
      Admin dengan 'system:admin' tetap bisa mengakses endpoint tertentu
      (misalnya /auth/permissions via require_auth),
      tetapi akan melewati jalur yang mem-filter permission '*' agar tidak terekspos.
    """
    if not user:
        return False

    perms = user.get("permissions") or []
    roles = [r.lower() for r in (user.get("roles") or [])]

    # Global wildcard: superadmin absolut
    if "*" in perms:
        return True

    # Role-based superadmin/developer
    if "superadmin" in roles:
        return True
    if "developer" in roles:
        return True

    return False

def check_permission(user_permissions, required_permissions):
    """
    Check if user has any of the required permissions
    Supports wildcard permissions (*, category:*)
    """
    if not required_permissions:
        return True

    # Admin wildcard permission
    if '*' in user_permissions:
        return True

    # Check each required permission
    for required in required_permissions:
        # Direct match
        if required in user_permissions:
            return True

        # Check category wildcard (e.g., 'patient:*' for 'patient:read')
        if ':' in required:
            category = required.split(':')[0]
            category_wildcard = f"{category}:*"
            if category_wildcard in user_permissions:
                return True

    return False

def require_auth(required_permissions=[]):
    """
    Decorator to require authentication and optionally check permissions

    Args:
        required_permissions: List of permission strings (OR logic - any match grants access)

    Permission System:
        - '*' = Admin wildcard (grants all permissions)
        - 'category:*' = Category wildcard (e.g., 'patient:*' grants patient:read, patient:write, etc.)
        - 'category:action' = Specific permission (e.g., 'patient:read')
    """
    def decorator(f):
        @wraps(f)
        def decorated(*args, **kwargs):
            # Allow CORS preflight without auth
            if request.method == 'OPTIONS':
                return ('', 204)

            auth_header = request.headers.get('Authorization')
            if not auth_header or not auth_header.startswith('Bearer '):
                logger.warning(f"Missing authorization header for {request.path}")
                return jsonify({
                    "status": "error",
                    "message": "Missing or invalid authorization header"
                }), 401

            token = auth_header.split(' ')[1]
            user = validate_token(token)

            if not user:
                logger.warning(f"Invalid token for {request.path}")
                return jsonify({
                    "status": "error",
                    "message": "Invalid or expired token"
                }), 401

            # Check permissions with enhanced logic
            if required_permissions:
                user_permissions = user.get('permissions', [])

                if not check_permission(user_permissions, required_permissions):
                    logger.warning(
                        f"Permission denied for user {user.get('username')} on {request.path}. "
                        f"Required: {required_permissions}, Has: {user_permissions}"
                    )
                    return jsonify({
                        "status": "error",
                        "message": "Insufficient permissions",
                        "required": required_permissions,
                        "hint": "Contact administrator to request access"
                    }), 403

            # Add user to request context
            request.current_user = user
            return f(*args, **kwargs)
        return decorated
    return decorator

def proxy_request(service_url, path, method, headers=None, data=None, raw_data=None, params=None):
    """Proxy request to backend service with proper forwarding headers"""
    try:
        url = f"{service_url}/{path}"
        safe_params = dict(params or {})
        logger.info(f"[gateway] proxy {method} {url} params={safe_params}")

        if headers is None:
            headers = {}

        # Forward authorization header unless explicitly overridden
        auth_header = request.headers.get('Authorization')
        if auth_header and 'Authorization' not in headers:
            headers['Authorization'] = auth_header

        # Forward real client IP:
        # - If incoming request already has X-Forwarded-For (e.g., from outer proxy), append our remote_addr.
        # - Else, start chain with client IP resolved by get_client_ip.
        client_ip = get_client_ip(request)
        existing_xff = request.headers.get("X-Forwarded-For")
        if existing_xff:
            headers["X-Forwarded-For"] = f"{existing_xff}, {client_ip}"
        else:
            headers["X-Forwarded-For"] = client_ip

        # Also set/override X-Real-IP for backend services
        headers["X-Real-IP"] = client_ip

        # Forward original User-Agent separately so backend can audit real client agent
        original_ua = request.headers.get("User-Agent")
        if original_ua:
            headers["X-Original-User-Agent"] = original_ua

        request_kwargs = {
            'method': method,
            'url': url,
            'headers': headers,
            'params': params,
            'timeout': 30
        }

        if raw_data is not None:
            request_kwargs['data'] = raw_data
        else:
            request_kwargs['json'] = data

        response = requests.request(**request_kwargs)
        ct = response.headers.get('Content-Type', '')
        logger.info(f"[gateway] proxy -> {response.status_code} {url}")

        if response.status_code >= 400:
            body_snippet = ''
            try:
                if ('json' in ct) or ('text' in ct):
                    body_snippet = response.text[:512]
                else:
                    body_snippet = f"<{len(response.content)} bytes>"
            except Exception:
                body_snippet = '<unreadable body>'
            logger.warning(
                f"[gateway] proxy error {method} {url} "
                f"status={response.status_code} body={body_snippet}"
            )

        return Response(response.content, status=response.status_code, headers=dict(response.headers))

    except requests.exceptions.RequestException as e:
        logger.error(f"[gateway] proxy exception {method} {service_url}/{path}: {str(e)}")
        return jsonify({
            "status": "error",
            "message": "Service unavailable",
            "detail": str(e)
        }), 503


def get_satusehat_config_from_settings():
    """
    Load SatuSehat configuration from settings table (integration_registry.satusehat).

    Expected structure:
      {
        "integration_registry": {
          "satusehat": {
            "env": "sandbox",
            "scope": "",
            "enabled": true,
            "clientId": "...",
            "clientSecret": "...",
            "tokenEndpoint": "...",
            "organizationId": "...",
            "timeoutMs": 10000
          }
        }
      }

    Returns dict or (None, error_message).
    """
    try:
        # Prefer dedicated key if available
        resp = requests.get(
            f"{MASTER_DATA_SERVICE_URL}/settings/integration_registry",
            timeout=10
        )

        if resp.status_code == 404:
            # Fall back to full settings and extract key
            resp = requests.get(f"{MASTER_DATA_SERVICE_URL}/settings", timeout=10)

        if resp.status_code != 200:
            logger.error(f"[satusehat] Failed to fetch settings, status={resp.status_code}")
            return None, f"Failed to fetch settings (status {resp.status_code})"

        data = resp.json()

        # Try various shapes safely
        integration_registry = None
        if isinstance(data, dict):
            if "integration_registry" in data:
                integration_registry = data.get("integration_registry")
            elif "value" in data and isinstance(data.get("value"), dict):
                # Some settings APIs return { key, value }
                val = data.get("value") or {}
                integration_registry = val.get("integration_registry", val)
            elif data.get("key") == "integration_registry" and "value" in data:
                integration_registry = data.get("value")

        if not integration_registry or not isinstance(integration_registry, dict):
            logger.error("[satusehat] integration_registry not found in settings")
            return None, "integration_registry not found in settings"

        satusehat_cfg = integration_registry.get("satusehat")
        if not satusehat_cfg or not isinstance(satusehat_cfg, dict):
            logger.error("[satusehat] satusehat config not found under integration_registry")
            return None, "satusehat config not found under integration_registry"

        if not satusehat_cfg.get("enabled", False):
            return None, "satusehat integration is disabled in settings"

        required = ["clientId", "clientSecret", "tokenEndpoint"]
        missing = [k for k in required if not satusehat_cfg.get(k)]
        if missing:
            return None, f"Missing satusehat config fields: {', '.join(missing)}"

        return satusehat_cfg, None

    except requests.RequestException as e:
        logger.error(f"[satusehat] Error fetching settings: {e}")
        return None, f"Failed to fetch settings: {e}"
    except ValueError as e:
        logger.error(f"[satusehat] Invalid JSON in settings response: {e}")
        return None, "Invalid JSON in settings response"

