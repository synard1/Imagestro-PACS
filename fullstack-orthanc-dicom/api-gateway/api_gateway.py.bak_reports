# ===== Permission Management Endpoints (Admin) =====

@app.route('/auth/permissions', methods=['GET'])
@require_auth(['system:admin', '*'])
def auth_permissions_list():
    """
    List all permissions.

    - Superadmin/developer (is_superadmin_or_dev == True):
      Mendapatkan daftar lengkap dari auth-service (termasuk '*' jika ada).
    - Admin dengan system:admin tapi bukan superadmin/developer:
      Boleh membaca daftar permission, namun permission '*' akan disembunyikan
      dari hasil response (tidak terekspos ke client tersebut).
    """
    user = request.current_user

    # Superadmin/developer: full access
    if is_superadmin_or_dev(user):
        return proxy_request(AUTH_SERVICE_URL, 'auth/permissions', 'GET')

    # Non-superadmin: sudah pasti punya system:admin (karena lolos require_auth),
    # tapi tidak dianggap superadmin/developer. Boleh list, tapi "*" harus difilter.
    # Teruskan Authorization header agar auth-service tetap mengenali user.
    try:
        headers = {}
        auth_header = request.headers.get("Authorization")
        if auth_header:
            headers["Authorization"] = auth_header

        resp = requests.get(
            f"{AUTH_SERVICE_URL}/auth/permissions",
            headers=headers,
            timeout=30
        )
    except requests.RequestException as e:
        logger.error(f"Error fetching permissions from auth-service: {e}")
        return jsonify({
            "status": "error",
            "message": "Failed to fetch permissions"
        }), 503

    # Jika bukan 200, forward apa adanya
    if resp.status_code != 200:
        return Response(resp.content, status=resp.status_code, headers=dict(resp.headers))

    # Coba parse JSON
    try:
        data = resp.json()
    except ValueError:
        # Kalau bukan JSON, kembalikan apa adanya
        return Response(resp.content, status=resp.status_code, headers=dict(resp.headers))

    def is_sensitive_perm(item):
        """
        Helper untuk deteksi permission yang hanya boleh terlihat oleh superadmin/developer.
        Saat ini:
        - "*" (global wildcard)
        - "setting:dev" (developer-only settings)
        Bisa diperluas jika ada permission lain yang super-sensitif.
        """
        # Ekstrak nama permission dari berbagai kemungkinan bentuk
        if isinstance(item, str):
            name = item.strip()
        elif isinstance(item, dict):
            name = (item.get("name")
                    or item.get("code")
                    or item.get("permission")
                    or item.get("value")
                    or "").strip()
        else:
            return False

        if name == "*":
            return True
        if name.lower() == "setting:dev":
            return True

        return False

    # Struktur umum 1: { "permissions": [...] }
    if isinstance(data, dict) and isinstance(data.get("permissions"), list):
        filtered = [p for p in data["permissions"] if not is_sensitive_perm(p)]
        data["permissions"] = filtered
        # Lanjutkan memfilter kategori lain di bawah.

    # Struktur umum 2: ada beberapa kategori sebagai list (misal "system": [...], "user": [...])
    if isinstance(data, dict):
        for key, value in list(data.items()):
            if isinstance(value, list):
                data[key] = [p for p in value if not is_sensitive_perm(p)]
        return jsonify(data), 200

    # Kalau langsung list
    if isinstance(data, list):
        filtered = [p for p in data if not is_sensitive_perm(p)]
        return jsonify(filtered), 200

    # Format lain: kembalikan tanpa modifikasi
    return jsonify(data), 200

@app.route('/auth/permissions', methods=['POST'])
@require_auth(['system:admin', '*'])
def auth_permissions_create():
    """
    Create new permission.

    Aturan:
    - Hanya superadmin/developer (is_superadmin_or_dev).
    - Dilarang membuat permission "*" (global wildcard) melalui API ini.
      Permission harus spesifik, contoh:
        - "patient:read"
        - "doctor:update"
        - "order:*" (masih diizinkan jika memang konsepnya kategori)
      Untuk mencegah injeksi paksa wildcard global.
    """
    user = request.current_user
    if not is_superadmin_or_dev(user):
        logger.warning(f"RBAC perm create denied for non-superadmin user {user.get('username')}")
        return jsonify({
            "status": "error",
            "message": "Insufficient role to create permissions",
            "hint": "Only superadmin/developer may create permissions"
        }), 403

    payload = request.get_json(silent=True) or {}

    # Normalisasi nama permission dari berbagai kemungkinan field
    perm_name = (
        payload.get("name")
        or payload.get("permission")
        or payload.get("code")
        or payload.get("value")
    )

    # Jika mencoba membuat permission "*" persis, tolak.
    if isinstance(perm_name, str) and perm_name.strip() == "*":
        logger.warning(f"Attempt to create global wildcard permission '*' blocked for user {user.get('username')}")
        return jsonify({
            "status": "error",
            "message": "Global wildcard permission '*' is not allowed via API. Use specific permissions.",
            "hint": "Define explicit permissions like 'patient:read', 'doctor:update', or scoped wildcards like 'patient:*' if needed."
        }), 400

    return proxy_request(AUTH_SERVICE_URL, 'auth/permissions', 'POST', data=payload)

