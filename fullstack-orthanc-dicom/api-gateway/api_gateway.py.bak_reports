@app.route('/accession/<path:path>', methods=['GET', 'POST', 'PUT', 'DELETE'])
@require_auth()
def accession_proxy(path):
    """Proxy accession requests with method-specific permissions"""
    user = request.current_user
    user_perms = user.get('permissions', [])
    
    method_required = {
        'GET': ['accession:read', '*'],
        'POST': ['accession:create', '*'],
        'PUT': ['accession:update', '*'],
        'DELETE': ['accession:delete', '*']
    }
    required = method_required.get(request.method, ['accession:read', '*'])
    
    if not check_permission(user_perms, required):
            logger.warning(f"Permission denied for {user.get('username')} on {request.method} /accession/{path}")
            return jsonify({
                "status": "error",
                "message": "Permission denied",
                "required": required
            }), 403
    
    try:
        response = proxy_request(ACCESSION_API_URL, f'api/{path}', request.method,
                                data=request.get_json(silent=True), params=request.args)
        return response
    except Exception as e:
        logger.error(f"Accession proxy error: {str(e)}")
        return jsonify({"status": "error", "message": "Failed to proxy request"}), 503

# ============================================================================
# API SERVICEREQUEST ROUTES (Frontend Compatibility)
# ============================================================================

@app.route('/api/servicerequest/create', methods=['POST', 'OPTIONS'])
def api_servicerequest_create():
    """ServiceRequest creation endpoint for frontend compatibility"""
    logger.info(f"API ServiceRequest create: {request.method}")
    
    # Handle CORS preflight
    if request.method == 'OPTIONS':
        response = make_response()
        response.headers.add("Access-Control-Allow-Origin", "*")
        response.headers.add('Access-Control-Allow-Headers', "*")
        response.headers.add('Access-Control-Allow-Methods', "*")
        return response
    
    # Ensure valid SatuSehat token
    try:
        health_response = requests.get(f"{SATUSEHAT_INTEGRATOR_URL}/oauth/health", timeout=5)
        
        if health_response.status_code == 200:
            health_data = health_response.json()
            if not health_data.get('valid', False):
                logger.info("SatuSehat token invalid, refreshing")
                refresh_response = requests.post(f"{SATUSEHAT_INTEGRATOR_URL}/oauth/refresh", timeout=10)
                if refresh_response.status_code != 200:
                    logger.error("Failed to refresh SatuSehat token")
                    return jsonify({'error': 'token_refresh_failed'}), 503
        else:
            logger.info("SatuSehat health check failed, generating new token")
            token_response = requests.post(f"{SATUSEHAT_INTEGRATOR_URL}/oauth/token", timeout=10)
            if token_response.status_code != 200:
                logger.error("Failed to generate SatuSehat token")
                return jsonify({'error': 'token_generation_failed'}), 503
                
    except requests.RequestException as e:
        logger.error(f"Error checking SatuSehat token: {e}")
        return jsonify({'error': 'service_unavailable'}), 503
    
    # Handle request body
    data = None
    if request.content_type and 'application/json' in request.content_type:
        try:
            data = request.get_json()
            logger.info(f"[gateway] API ServiceRequest payload received from frontend: {data}")
        except Exception as e:
            logger.error(f"[gateway] Failed to parse JSON body: {e}")
            return jsonify({'error': 'invalid_json', 'message': 'Request body is not valid JSON'}), 400
    
    # Forward to satusehat-integrator servicerequest endpoint
    return proxy_request(SATUSEHAT_INTEGRATOR_URL, 'servicerequest', 'POST', data=data)

# ============================================================================
# SATUSEHAT INTEGRATOR ROUTES
# ============================================================================

@app.route('/satusehat/token/generate', methods=['POST'])
@require_auth(['system:admin', 'setting:write', '*'])
def satusehat_generate_token():
    """
    Generate or retrieve SatuSehat token with rate-limit friendly behavior.

    Prioritas:
    1. Jika satusehat-integrator melaporkan token masih valid (via /oauth/health),
       ambil token dari satusehat-integrator (/oauth/token) tanpa memukul server SatuSehat.
    2. Jika tidak valid / gagal, generate token baru langsung ke SatuSehat
       menggunakan konfigurasi dari settings.integration_registry.satusehat.

    Catatan:
    - Mengurangi risiko rate limit dengan memanfaatkan caching/token management di satusehat-integrator.
    - Endpoint ini hanya boleh diakses oleh admin (setting:write atau *).
    """
    # 1) Cek ke satusehat-integrator apakah token masih valid
    try:
        health_resp = requests.get(
            f"{SATUSEHAT_INTEGRATOR_URL}/oauth/health",
            timeout=5
        )
        if health_resp.status_code == 200:
            health_data = health_resp.json()
            if health_data.get("valid"):
                # Token masih valid menurut integrator -> minta token dari integrator
                try:
                    token_resp = requests.get(
                        f"{SATUSEHAT_INTEGRATOR_URL}/oauth/token",
                        timeout=5
                    )
                    ct = token_resp.headers.get("Content-Type", "")
                    try:
                        token_body = token_resp.json() if "json" in ct else {"raw": token_resp.text[:2048]}
                    except ValueError:
                        token_body = {"raw": token_resp.text[:2048]}

                    if token_resp.status_code == 200:
                        logger.info("[satusehat] Using existing valid token from satusehat-integrator")
                        return jsonify({
                            "status": "ok",
                            "source": "cache",
                            "integrator": True,
                            "token": token_body
                        }), 200
                    else:
                        logger.warning(
                            f"[satusehat] integrator /oauth/token returned {token_resp.status_code}, "
                            f"will fallback to direct generation"
                        )
                except requests.RequestException as e:
                    logger.warning(f"[satusehat] Failed to get token from integrator: {e}, fallback to direct")
        else:
            logger.info(
                f"[satusehat] integrator /oauth/health status={health_resp.status_code}, "
                "will fallback to direct generation"
            )
    except requests.RequestException as e:
        logger.warning(f"[satusehat] integrator /oauth/health error: {e}, fallback to direct")

    # 2) Fallback: generate token baru langsung ke SatuSehat berdasarkan settings
    cfg, err = get_satusehat_config_from_settings()
    if err:
        return jsonify({
            "status": "error",
            "message": err
        }), 400

    token_endpoint = cfg["tokenEndpoint"]
    client_id = cfg["clientId"]
    client_secret = cfg["clientSecret"]
    scope = cfg.get("scope") or ""
    timeout_ms = cfg.get("timeoutMs") or 10000

    payload = {
        "grant_type": "client_credentials",
        "client_id": client_id,
        "client_secret": client_secret,
    }
    if scope:
        payload["scope"] = scope

    headers = {
        "Content-Type": "application/x-www-form-urlencoded"
    }

    try:
        timeout = max(1, int(timeout_ms / 1000))
    except Exception:
        timeout = 10

    try:
        logger.info(
            f"[satusehat] Requesting NEW token from {token_endpoint} "
            f"(env={cfg.get('env', 'unknown')}) via client_credentials"
        )
        resp = requests.post(token_endpoint, data=payload, headers=headers, timeout=timeout)

        content_type = resp.headers.get("Content-Type", "")
        try:
            body = resp.json() if "json" in content_type else {"raw": resp.text[:2048]}
        except ValueError:
            body = {"raw": resp.text[:2048]}

        if resp.status_code != 200:
            logger.error(f"[satusehat] Direct token generation failed: {resp.status_code} {body}")
            return jsonify({
                "status": "error",
                "message": "Failed to generate SatuSehat token",
                "status_code": resp.status_code,
                "response": body
            }), 502

        logger.info("[satusehat] New token generated successfully via gateway (direct)")

        # Sync token ke satusehat-integrator agar:
        # - Disimpan ke satusehat_tokens
        # - Di-upsert ke settings (satusehat_latest_token)
        try:
          sync_payload = {
              "access_token": body.get("access_token"),
              "token_type": body.get("token_type"),
              "expires_in": body.get("expires_in"),
              "scope": body.get("scope"),
              "issued_at": body.get("issued_at"),
              "organizationId": cfg.get("organizationId"),
          }
          # Hanya kirim kalau ada access_token
          if sync_payload["access_token"]:
              sync_resp = requests.post(
                  f"{SATUSEHAT_INTEGRATOR_URL}/oauth/token/store",
                  json=sync_payload,
                  timeout=5
              )
              if sync_resp.status_code != 200:
                  logger.warning(
                      f"[satusehat] Failed to sync token to integrator: "
                      f"status={sync_resp.status_code} body={sync_resp.text[:256]}"
                  )
          else:
              logger.warning("[satusehat] Missing access_token in direct response; skip sync to integrator")
        except requests.RequestException as e:
          logger.warning(f"[satusehat] Error syncing token to satusehat-integrator: {e}")

        return jsonify({
            "status": "ok",
            "source": "direct",
            "env": cfg.get("env"),
            "organizationId": cfg.get("organizationId"),
            "tokenEndpoint": token_endpoint,
            "token": body
        }), 200

    except requests.RequestException as e:
        logger.error(f"[satusehat] Error calling SatuSehat token endpoint: {e}")
        return jsonify({
            "status": "error",
            "message": "Error calling SatuSehat token endpoint",
            "detail": str(e)
        }), 503


@app.route('/satusehat/<path:path>', methods=['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'])
def satusehat_proxy(path):
    """Enhanced SatuSehat proxy with automatic token management"""
    logger.info(f"SatuSehat proxy: {request.method} /{path}")
    
    # Handle CORS preflight
    if request.method == 'OPTIONS':
        response = make_response()
        response.headers.add("Access-Control-Allow-Origin", "*")
        response.headers.add('Access-Control-Allow-Headers', "*")
        response.headers.add('Access-Control-Allow-Methods', "*")
        return response
    
    # Token endpoints - no auth required
    if path in ['oauth/token', 'oauth/health', 'oauth/refresh']:
        return proxy_request(SATUSEHAT_INTEGRATOR_URL, path, request.method)
    
    # FHIR endpoints - ensure valid token
    if path.startswith('location') or path in ['patient', 'practitioner', 'encounter', 'servicerequest']:
        try:
            health_response = requests.get(f"{SATUSEHAT_INTEGRATOR_URL}/oauth/health", timeout=5)
            
            if health_response.status_code == 200:
                health_data = health_response.json()
                if not health_data.get('valid', False):
                    logger.info("SatuSehat token invalid, refreshing")
                    refresh_response = requests.post(f"{SATUSEHAT_INTEGRATOR_URL}/oauth/refresh", timeout=10)
                    if refresh_response.status_code != 200:
                        logger.error("Failed to refresh SatuSehat token")
                        return jsonify({'error': 'token_refresh_failed'}), 503
            else:
                logger.info("SatuSehat health check failed, generating new token")
                token_response = requests.post(f"{SATUSEHAT_INTEGRATOR_URL}/oauth/token", timeout=10)
                if token_response.status_code != 200:
                    logger.error("Failed to generate SatuSehat token")
                    return jsonify({'error': 'token_generation_failed'}), 503
                    
        except requests.RequestException as e:
            logger.error(f"Error checking SatuSehat token: {e}")
            return jsonify({'error': 'service_unavailable'}), 503
    
    # Other endpoints require user authentication
    elif not path.startswith('health') and not path.startswith('ready'):
        auth_header = request.headers.get('Authorization')
        if not auth_header or not auth_header.startswith('Bearer '):
            return jsonify({'error': 'unauthorized', 'message': 'Missing authorization'}), 401
        
        token = auth_header.split(' ')[1]
        user = validate_token(token)
        if not user:
            return jsonify({'error': 'unauthorized', 'message': 'Invalid token'}), 401
    
    return proxy_request(SATUSEHAT_INTEGRATOR_URL, path, request.method)

