        data=request.get_json(silent=True)
    )


@app.route('/orders/<path:path>', methods=['GET', 'POST', 'PUT', 'DELETE'])
@require_auth()
def orders_proxy(path):
    """
    Proxy order management requests for subpaths under /orders/*.

    Permission mapping (method-based):
    - GET    -> order:read
    - POST   -> order:create
    - PUT    -> order:update
    - DELETE -> order:delete
    """
    user = request.current_user
    user_perms = user.get('permissions', []) or []

    method_required = {
        'GET': ['order:read', '*'],
        'POST': ['order:create', '*'],
        'PUT': ['order:update', '*'],
        'DELETE': ['order:delete', '*']
    }
    required = method_required.get(request.method, ['order:read', '*'])

    if not check_permission(user_perms, required):
        logger.warning(
            f"Permission denied for user {user.get('username')} on {request.method} /orders/{path}. "
            f"Required: {required}, Has: {user_perms}"
        )
        return jsonify({
            "status": "error",
            "message": "Permission denied",
            "required": required
        }), 403

    # If content-type is multipart/form-data, forward raw body to support file uploads.
    content_type = (request.headers.get('Content-Type') or '').lower()
    if content_type.startswith('multipart/form-data'):
        # Forward multipart body as-is, but strip Host/Content-Length so requests can set them correctly.
        fwd_headers = {
            k: v
            for k, v in request.headers
            if k.lower() not in ('host', 'content-length')
        }
        return proxy_request(
            ORDER_SERVICE_URL,
            f'orders/{path}',
            request.method,
            headers=fwd_headers,
            raw_data=request.get_data(),
            params=request.args
        )

    # Default: JSON / standard proxy
    return proxy_request(
        ORDER_SERVICE_URL,
        f'orders/{path}',
        request.method,
        data=request.get_json(silent=True),
        params=request.args
    )


@app.route('/orders/<identifier>/files/<file_id>/content', methods=['GET'])
@require_auth(['order:read', '*'])
def orders_file_content_proxy(identifier, file_id):
    """
    Proxy to download/stream physical order file content via gateway.

    Maps:
      GET /orders/<identifier>/files/<file_id>/content (gateway)
      ->  GET /orders/<identifier>/files/<file_id>/content (order-management)
    """
    # Forward as-is (no JSON body), preserving query params if any.
    # Strip Host so downstream requests can set it properly.
    fwd_headers = {
        k: v
        for k, v in request.headers
        if k.lower() not in ('host', 'content-length')
    }
    # Construct relative path used by order-management service
    om_path = f"orders/{identifier}/files/{file_id}/content"
    return proxy_request(
        ORDER_SERVICE_URL,
        om_path,
        'GET',
        headers=fwd_headers,
        raw_data=None,
        params=request.args
    )

# ============================================================================
# ACCESSION API ROUTES (CONSOLIDATED - NO DUPLICATES)
# ============================================================================

@app.route('/accession/create', methods=['POST'])
@require_auth(['accession:create', '*'])
def accession_create():
    """Create new accession number"""
    user = request.current_user
    logger.info(f"Accession create by user: {user.get('username', 'unknown')}")
    
    try:
        incoming = request.get_json() or {}
        # Backward-compatible transform
        if 'patient' in incoming:
            p = incoming.get('patient') or {}
            transformed = {
                'modality': incoming.get('modality') or incoming.get('modalityType') or incoming.get('modality_type'),
                'procedure_code': incoming.get('procedure_code') or incoming.get('studyDescription'),
                'procedure_name': incoming.get('procedure_name'),
                'scheduled_at': incoming.get('scheduled_at'),
                'patient_national_id': p.get('id'),
                'patient_name': p.get('name'),
                'gender': p.get('sex'),
                'birth_date': p.get('birthDate'),
                'medical_record_number': p.get('medical_record_number'),
                'ihs_number': p.get('ihs_number'),
                'registration_number': incoming.get('registration_number')
            }
            payload = transformed
        else:
            payload = incoming
        
        response = proxy_request(ACCESSION_API_URL, 'accession/create', 'POST', data=payload)
        logger.info(f"Accession create response: {response.status_code}")
        return response
    except Exception as e:
        logger.error(f"Accession create error: {str(e)}")
        return jsonify({"status": "error", "message": "Failed to create accession"}), 503

