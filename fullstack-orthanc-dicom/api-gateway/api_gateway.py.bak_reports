# ===== Public Auth Endpoints (No Auth Required) =====

@app.route('/auth/login', methods=['POST'])
@limiter.limit(lambda: GATEWAY_LOGIN_LIMIT)
def auth_login():
    """Login endpoint - no auth required"""
    return proxy_request(AUTH_SERVICE_URL, 'auth/login', 'POST', data=request.get_json(silent=True))

@app.route('/auth/verify', methods=['POST'])
@limiter.limit(lambda: GATEWAY_VERIFY_LIMIT)
def auth_verify():
    """Verify token via auth-service - no auth required"""
    return proxy_request(AUTH_SERVICE_URL, 'auth/verify', 'POST', data=request.get_json(silent=True))

@app.route('/auth/register', methods=['POST'])
@limiter.limit(lambda: GATEWAY_REGISTER_LIMIT)
def auth_register_public():
    """Public user registration endpoint (if enabled)"""
    return proxy_request(AUTH_SERVICE_URL, 'auth/register', 'POST', data=request.get_json(silent=True))

# ===== User Profile Endpoints =====

@app.route('/auth/me', methods=['GET'])
@require_auth()
def auth_me():
    """Get current user profile"""
    return proxy_request(AUTH_SERVICE_URL, 'auth/me', 'GET')

@app.route('/auth/change-password', methods=['POST'])
@require_auth()
def auth_change_password():
    """Change current user password"""
    return proxy_request(AUTH_SERVICE_URL, 'auth/change-password', 'POST', data=request.get_json(silent=True))

# ===== User Management Endpoints (Admin) =====

@app.route('/auth/users', methods=['GET'])
@require_auth(['user:read', 'user:manage', '*'])
def auth_users_list():
    """
    List all users.

    Akses dikontrol oleh permission:
    - Diizinkan jika user memiliki salah satu:
      - user:read
      - user:manage
      - atau '*' (via require_auth)

    Catatan:
    - Tidak lagi diwajibkan is_superadmin_or_dev.
    - Admin tanpa '*' tapi dengan user:manage tetap bisa melihat daftar user.
    """
    return proxy_request(AUTH_SERVICE_URL, 'auth/users', 'GET', params=request.args)

@app.route('/auth/users', methods=['POST'])
@require_auth(['user:create', 'user:manage', '*'])
def auth_users_create():
    """Create new user - requires user:create permission"""
    return proxy_request(AUTH_SERVICE_URL, 'auth/users', 'POST', data=request.get_json(silent=True))

@app.route('/auth/users/<user_id>', methods=['GET'])
@require_auth(['user:read', 'user:manage', '*'])
def auth_users_get(user_id):
    """Get user by ID - requires user:read permission"""
    return proxy_request(AUTH_SERVICE_URL, f'auth/users/{user_id}', 'GET')

@app.route('/auth/users/<user_id>', methods=['PUT'])
@require_auth(['user:update', 'user:manage', '*'])
def auth_users_update(user_id):
    """Update user - requires user:update permission"""
    return proxy_request(AUTH_SERVICE_URL, f'auth/users/{user_id}', 'PUT', data=request.get_json(silent=True))

@app.route('/auth/users/<user_id>', methods=['DELETE'])
@require_auth(['user:delete', 'user:manage', '*'])
def auth_users_delete(user_id):
    """Delete user - requires user:delete permission"""
    return proxy_request(AUTH_SERVICE_URL, f'auth/users/{user_id}', 'DELETE')

@app.route('/auth/users/<user_id>/change-password', methods=['POST'])
@require_auth(['user:update', 'user:manage', '*'])
def auth_users_change_password(user_id):
    """Change user password - requires user:update permission"""
    return proxy_request(AUTH_SERVICE_URL, f'auth/users/{user_id}/change-password', 'POST',
                        data=request.get_json(silent=True))

@app.route('/auth/users/<user_id>/activate', methods=['POST'])
@require_auth(['user:manage', '*'])
def auth_users_activate(user_id):
    """Activate user account - requires user:manage permission"""
    return proxy_request(AUTH_SERVICE_URL, f'auth/users/{user_id}/activate', 'POST')

@app.route('/auth/users/<user_id>/deactivate', methods=['POST'])
@require_auth(['user:manage', '*'])
def auth_users_deactivate(user_id):
    """Deactivate user account - requires user:manage permission"""
    return proxy_request(AUTH_SERVICE_URL, f'auth/users/{user_id}/deactivate', 'POST')

# ===== Role Management Endpoints (Admin) =====

@app.route('/auth/roles', methods=['GET'])
@require_auth(['system:admin', '*'])
def auth_roles_list():
    """
    List all roles.

    - Hanya pengguna dengan 'system:admin' atau '*' yang boleh mengakses endpoint ini
      (divalidasi oleh require_auth).
    - Superadmin/developer (is_superadmin_or_dev == True):
      Mendapat daftar lengkap roles langsung dari auth-service.
    - Admin dengan 'system:admin' tetapi bukan superadmin/developer:
      Tetap diperbolehkan melihat daftar roles.
      (Jika suatu saat perlu menyembunyikan role super-sensitif seperti 'superadmin',
       filtering bisa ditambahkan di sini.)
    """
    user = request.current_user

    # Superadmin/developer: akses penuh
    if is_superadmin_or_dev(user):
        return proxy_request(AUTH_SERVICE_URL, 'auth/roles', 'GET')

    # Admin biasa dengan system:admin (lolos require_auth) juga boleh melihat roles
    logger.info(f"RBAC roles list allowed for admin user {user.get('username')}")
    return proxy_request(AUTH_SERVICE_URL, 'auth/roles', 'GET')

@app.route('/auth/roles', methods=['POST'])
@require_auth(['system:admin', '*'])
def auth_roles_create():
    """Create new role - admin only (superadmin/developer via is_superadmin_or_dev)"""
    user = request.current_user
    if not is_superadmin_or_dev(user):
        logger.warning(f"RBAC create role denied for non-superadmin user {user.get('username')}")
        return jsonify({
            "status": "error",
            "message": "Insufficient role to create roles",
            "hint": "Only superadmin/developer may create roles"
        }), 403
    return proxy_request(AUTH_SERVICE_URL, 'auth/roles', 'POST', data=request.get_json(silent=True))

@app.route('/auth/roles/<role_name>', methods=['GET'])
@require_auth(['system:admin', '*'])
def auth_roles_get(role_name):
    """
    Get role details - admin only.
    Dibatasi ke superadmin/developer agar konfigurasi roles sensitif tidak terekspos.
    """
    user = request.current_user
    if not is_superadmin_or_dev(user):
        logger.warning(f"RBAC get role denied for non-superadmin user {user.get('username')}")
        return jsonify({
            "status": "error",
            "message": "Insufficient role to view this role detail",
            "hint": "Only superadmin/developer may view role details"
        }), 403
    return proxy_request(AUTH_SERVICE_URL, f'auth/roles/{role_name}', 'GET')

@app.route('/auth/roles/<role_name>/users', methods=['GET'])
@require_auth(['system:admin', '*'])
def auth_roles_users(role_name):
    """
    Get users assigned to role - admin only.
    Hanya untuk superadmin/developer untuk menghindari kebocoran mapping user-role sensitif.
    """
    user = request.current_user
    if not is_superadmin_or_dev(user):
        logger.warning(f"RBAC role users list denied for non-superadmin user {user.get('username')}")
        return jsonify({
            "status": "error",
            "message": "Insufficient role to view users of this role",
            "hint": "Only superadmin/developer may view users of a role"
        }), 403
    return proxy_request(AUTH_SERVICE_URL, f'auth/roles/{role_name}/users', 'GET', params=request.args)

