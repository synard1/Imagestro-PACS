# --- PACS CATCH-ALL ---
@app.route('/api', defaults={'path': ''}, methods=['GET', 'POST', 'PUT', 'PATCH', 'DELETE', 'OPTIONS'])
@app.route('/api/<path:path>', methods=['GET', 'POST', 'PUT', 'PATCH', 'DELETE', 'OPTIONS'])
def api_proxy(path):
    target = f"api/{path}" if path else "api"
    return proxy_request(PAC_SERVICE_URL, target, request.method, params=request.args)

@app.route('/wado-rs/<path:path>', methods=['GET', 'OPTIONS'])
def wado_proxy(path):
    return proxy_request(PAC_SERVICE_URL, f"wado-rs/{path}", "GET", params=request.args)

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=8888)
