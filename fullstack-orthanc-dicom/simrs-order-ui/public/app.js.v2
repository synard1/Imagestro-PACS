/**
 * SIMRS Order UI - Main Application Entry Point
 *
 * This is the main application file that orchestrates all modules and provides
 * the core application functionality. It has been refactored to use a clean,
 * modular architecture for better maintainability and scalability.
 *
 * @version 2.0.0 (Refactored)
 * @author SIMRS Order UI Team
 * @date 2024
 *
 * REFACTORING NOTES:
 * - Extracted utilities to dedicated modules (dom.js, date.js, storage.js)
 * - Moved API calls to service layer (api.js)
 * - Implemented centralized state management (state.js)
 * - Added comprehensive validation system (validation.js)
 * - Created reusable UI components (ui.js)
 * - Implemented authentication module (auth.js)
 * - Added proper error handling and logging
 * - Improved code organization and documentation
 */

// Import all required modules
import { APP_CONFIG, API_ENDPOINTS, MESSAGES } from "./js/config/constants.js";
import {
  qs,
  qsa,
  showToast,
  setValue,
  getValue,
  setText,
  toggleVisibility,
} from "./js/utils/dom.js";
import {
  formatDateLocal,
  formatRegistration,
  parseDate,
  addHours,
} from "./js/utils/date.js";
import {
  AuthStorage,
  LocationCache,
  SuggestionsCache,
  RegistrationSequence,
} from "./js/utils/storage.js";
import {
  AuthApi,
  ConfigApi,
  StaticDataApi,
  SatusehatApi,
  OrdersApi,
  apiService,
} from "./js/services/api.js";
import { AuthManager } from "./js/modules/auth.js";
import {
  FormManager,
  TableManager,
  ModalManager,
  AutocompleteManager,
} from "./js/modules/ui.js";
import {
  ValidationSchemas,
  BusinessRules,
  ValidationUtils,
} from "./js/modules/validation.js";
import State from "./js/modules/state.js";

/**
 * Main Application Class
 *
 * This class orchestrates all application modules and provides the main
 * application lifecycle management.
 */
class SimrsOrderApp {
  constructor() {
    this.isInitialized = false;
    this.modules = {};
    this.eventListeners = new Map();

    // Initialize core modules
    this.initializeModules();

    // Bind methods to preserve context
    this.bindMethods();
  }

  /**
   * Initialize all application modules
   */
  initializeModules() {
    try {
      // Initialize authentication manager
      this.modules.auth = new AuthManager();

      // Initialize UI managers
      this.modules.forms = new FormManager();
      this.modules.tables = new TableManager();
      this.modules.modals = new ModalManager();
      this.modules.autocomplete = new AutocompleteManager();

      // Initialize validation schemas
      this.modules.validation = {
        schemas: ValidationSchemas,
        rules: BusinessRules,
        utils: ValidationUtils,
      };

      console.log("Application modules initialized successfully");
    } catch (error) {
      console.error("Failed to initialize application modules:", error);
      showToast(MESSAGES.INITIALIZATION_FAILED, "error");
    }
  }

  /**
   * Bind methods to preserve context
   */
  bindMethods() {
    this.handleLogin = this.handleLogin.bind(this);
    this.handleLogout = this.handleLogout.bind(this);
    this.handleOrderSubmit = this.handleOrderSubmit.bind(this);
    this.handleServiceRequestCreate =
      this.handleServiceRequestCreate.bind(this);
    this.handleSimOrderActions = this.handleSimOrderActions.bind(this);
    this.handlePatientSearch = this.handlePatientSearch.bind(this);
    this.handlePractitionerSearch = this.handlePractitionerSearch.bind(this);
    this.handleSimOrderSelect = this.handleSimOrderSelect.bind(this);
    this.handlePatientSelect = this.handlePatientSelect.bind(this);
    this.handlePractitionerSelect = this.handlePractitionerSelect.bind(this);
    this.handlePatientAutocomplete = this.handlePatientAutocomplete.bind(this);
    this.handlePractitionerAutocomplete =
      this.handlePractitionerAutocomplete.bind(this);
    this.handleFormValidation = this.handleFormValidation.bind(this);
  }

  /**
   * Initialize the application
   */
  async initialize() {
    if (this.isInitialized) {
      console.warn("Application already initialized");
      return;
    }

    try {
      console.log("Initializing SIMRS Order UI Application...");

      // Show loading state
      State.app.setLoading(true);

      // Load configuration
      await this.loadConfiguration();

      // Initialize authentication
      await this.initializeAuthentication();

      // Setup event listeners
      this.setupEventListeners();

      // Initialize UI components
      await this.initializeUI();

      // Load initial data
      await this.loadInitialData();

      // Setup state subscriptions
      this.setupStateSubscriptions();

      // Mark as initialized
      this.isInitialized = true;

      console.log("Application initialized successfully");
      showToast(MESSAGES.INITIALIZATION_COMPLETE, "success");
    } catch (error) {
      console.error("Application initialization failed:", error);
      showToast(MESSAGES.INITIALIZATION_FAILED, "error");
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Load application configuration
   */
  async loadConfiguration() {
    try {
      const config = await ConfigApi.fetchConfig();
      State.app.setConfig(config);
      console.log("Configuration loaded:", config);
    } catch (error) {
      console.warn("Failed to load configuration, using defaults:", error);
      // Use default configuration
      State.app.setConfig({
        gateway_base: APP_CONFIG.DEFAULT_GATEWAY_BASE,
      });
    }
  }

  /**
   * Initialize authentication
   */
  async initializeAuthentication() {
    try {
      // Check for existing authentication
      const token = AuthStorage.getToken();

      if (token) {
        // Validate token and restore session
        try {
          // Check if auth module is properly initialized
          if (
            !this.modules.auth ||
            typeof this.modules.auth.validateToken !== "function"
          ) {
            console.error("Auth module not properly initialized");
            return;
          }

          const isValid = await this.modules.auth.validateToken(token);
          if (isValid) {
            // Get user data (either from storage or from token validation)
            let user = AuthStorage.getUser();
            if (!user && this.modules.auth.currentUser) {
              // If user data wasn't in storage but was retrieved during validation
              user = this.modules.auth.currentUser;
              AuthStorage.setUser(user); // Store it for future use
            }

            if (user) {
              State.auth.login(user, token);
              console.log("Session restored for user:", user.username);
            } else {
              console.warn("Token is valid but no user data available");
              if (
                this.modules.auth &&
                typeof this.modules.auth.logout === "function"
              ) {
                this.modules.auth.logout();
              }
            }
          } else {
            // Clear invalid session
            console.log("Token validation failed, clearing session");
            if (
              this.modules.auth &&
              typeof this.modules.auth.logout === "function"
            ) {
              this.modules.auth.logout();
            }
          }
        } catch (validationError) {
          console.error("Token validation error:", validationError);
          // Handle specific error types
          if (
            validationError.message &&
            validationError.message.includes("404")
          ) {
            console.warn(
              "Token verification endpoint not found (404), clearing session"
            );
          } else if (
            validationError.name === "NetworkError" ||
            validationError.message.includes("fetch")
          ) {
            console.warn(
              "Network error during token validation, keeping session for now"
            );
            return; // Don't logout on network errors, user might be offline
          }

          // Clear session for other errors
          if (
            this.modules.auth &&
            typeof this.modules.auth.logout === "function"
          ) {
            this.modules.auth.logout();
          }
        }
      }
    } catch (error) {
      console.error("Authentication initialization failed:", error);
      // Only logout if auth module is available
      if (this.modules.auth && typeof this.modules.auth.logout === "function") {
        this.modules.auth.logout();
      }
    }
  }

  /**
   * Setup event listeners
   */
  setupEventListeners() {
    // Authentication events
    this.addEventListener("#btn-login", "click", this.handleLogin.bind(this));
    this.addEventListener("#btn-logout", "click", this.handleLogout.bind(this));

    // Order management events
    this.addEventListener("#btn-submit-order", "click", this.handleOrderSubmit);
    this.addEventListener(
      "#btn-create-service-request",
      "click",
      this.handleServiceRequestCreate
    );
    this.addEventListener(
      "#btn-copy-from-order",
      "click",
      this.copyFromOrderToServiceRequest.bind(this)
    );

    // Sim order events
    this.addEventListener(
      "#sim-orders-table",
      "click",
      this.handleSimOrderActions
    );
    this.addEventListener(
      "#btn-save-sim-order",
      "click",
      this.saveSimOrder.bind(this)
    );
    this.addEventListener(
      "#btn-load-orders",
      "click",
      this.loadSimOrders.bind(this)
    );

    // Search events
    this.addEventListener(
      "#btn-patient-search",
      "click",
      this.handlePatientSearch
    );
    this.addEventListener(
      "#btn-practitioner-search",
      "click",
      this.handlePractitionerSearch
    );
    this.addEventListener(
      "#btn-procedure-search",
      "click",
      this.loadProcedureCatalog.bind(this)
    );

    // Form events
    this.addEventListener("#patient_id", "input", this.handleFormValidation);
    this.addEventListener(
      "#practitioner_id",
      "input",
      this.handleFormValidation
    );
    this.addEventListener(
      "#scheduled_date",
      "change",
      this.handleScheduleChange.bind(this)
    );
    this.addEventListener(
      "#scheduled_time",
      "change",
      this.handleScheduleChange.bind(this)
    );
    this.addEventListener(
      "#service_type",
      "change",
      this.handleServiceTypeChange.bind(this)
    );

    // Preset events
    this.addEventListener(
      "#btn-apply-dummy",
      "click",
      this.applyDummyFromPreset.bind(this)
    );

    // Auto-selection events
    this.addEventListener(
      "#btn-auto-h7",
      "click",
      this.autoSelectHMinus7.bind(this)
    );

    console.log("Event listeners setup completed");
  }

  /**
   * Helper method to add event listeners with cleanup tracking
   */
  addEventListener(selector, event, handler) {
    const element = qs(selector);
    if (element) {
      element.addEventListener(event, handler);

      // Track for cleanup
      const key = `${selector}:${event}`;
      if (!this.eventListeners.has(key)) {
        this.eventListeners.set(key, []);
      }
      this.eventListeners.get(key).push({ element, event, handler });
    }
  }

  /**
   * Initialize UI components
   */
  async initializeUI() {
    try {
      // Register forms
      this.modules.forms.registerForm("#order-form", {
        validation: ValidationSchemas.orderForm,
        autoSave: true,
        onSubmit: this.handleOrderSubmit,
      });

      this.modules.forms.registerForm("#service-request-form", {
        validation: ValidationSchemas.serviceRequest,
        onSubmit: this.handleServiceRequestCreate,
      });

      this.modules.forms.registerForm("#patient-registration-form", {
        selector: "#patient-registration-form",
        validation: ValidationSchemas.patientRegistration,
      });

      // Register tables
      this.modules.tables.registerTable("#sim-orders-table", {
        sortable: true,
        selectable: true,
        onRowSelect: this.handleSimOrderSelect.bind(this),
      });

      this.modules.tables.registerTable("#patient-results", {
        selectable: true,
        onRowSelect: this.handlePatientSelect.bind(this),
      });

      this.modules.tables.registerTable("#practitioner-results", {
        selectable: true,
        onRowSelect: this.handlePractitionerSelect.bind(this),
      });

      // Register modals
      this.modules.modals.registerModal("#order-preview-modal");
      this.modules.modals.registerModal("#patient-search-modal");
      this.modules.modals.registerModal("#practitioner-search-modal");

      // Register autocomplete
      this.modules.autocomplete.registerAutocomplete("#patient_id", {
        input: "#patient_id",
        datalist: "#patient-suggestions",
        minLength: 2,
        onSelect: this.handlePatientAutocomplete.bind(this),
      });

      this.modules.autocomplete.registerAutocomplete("#practitioner_id", {
        input: "#practitioner_id",
        datalist: "#practitioner-suggestions",
        minLength: 2,
        onSelect: this.handlePractitionerAutocomplete.bind(this),
      });

      console.log("UI components initialized");
    } catch (error) {
      console.error("UI initialization failed:", error);
      throw error;
    }
  }

  /**
   * Load initial data
   */
  async loadInitialData() {
    try {
      // Load static data in parallel
      const [locations, procedures] = await Promise.allSettled([
        this.loadSatusehatLocations(),
        this.loadProcedureCatalog(),
      ]);

      if (locations.status === "rejected") {
        console.warn("Failed to load locations:", locations.reason);
      }

      if (procedures.status === "rejected") {
        console.warn("Failed to load procedures:", procedures.reason);
      }

      // Load suggestions from cache
      this.loadCachedSuggestions();

      console.log("Initial data loaded");
    } catch (error) {
      console.error("Failed to load initial data:", error);
    }
  }

  /**
   * Setup state subscriptions
   */
  setupStateSubscriptions() {
    // Authentication state changes
    State.subscribe("auth.isAuthenticated", (isAuthenticated) => {
      this.handleAuthenticationChange(isAuthenticated);
    });

    // Loading state changes
    State.subscribe("app.isLoading", (isLoading) => {
      this.handleLoadingChange(isLoading);
    });

    // Error state changes
    State.subscribe("app.error", (error) => {
      if (error) {
        showToast(error, "error");
        State.app.clearError();
      }
    });

    // Active order changes
    State.subscribe("data.activeOrder", (order) => {
      this.handleActiveOrderChange(order);
    });

    console.log("State subscriptions setup completed");
  }

  /**
   * Handle authentication state changes
   */
  handleAuthenticationChange(isAuthenticated) {
    const loginSection = qs("#login-section");
    const appSection = qs("#app-section");

    if (isAuthenticated) {
      toggleVisibility(loginSection, false);
      toggleVisibility(appSection, true);

      // Load user-specific data
      this.loadUserData();
    } else {
      toggleVisibility(loginSection, true);
      toggleVisibility(appSection, false);

      // Clear user data
      this.clearUserData();
    }
  }

  /**
   * Handle loading state changes
   */
  handleLoadingChange(isLoading) {
    const loadingIndicator = qs("#loading-indicator");
    if (loadingIndicator) {
      toggleVisibility(loadingIndicator, isLoading);
    }

    // Disable/enable form inputs during loading
    const forms = qsa("form");
    forms.forEach((form) => {
      const inputs = form.querySelectorAll("input, button, select, textarea");
      inputs.forEach((input) => {
        input.disabled = isLoading;
      });
    });
  }

  /**
   * Handle active order changes
   */
  handleActiveOrderChange(order) {
    const activeOrderIdInput = qs("#active_sim_order_id");
    if (activeOrderIdInput) {
      activeOrderIdInput.value = order ? order.id : "";
    }

    // Update copy button status if method exists
    if (typeof this.updateCopyButtonStatus === 'function') {
      this.updateCopyButtonStatus();
    }
  }

  /**
   * Update copy button status based on encounter ID
   */
  updateCopyButtonStatus() {
    const encounterId = qs("#satusehat_encounter_id")?.value || "";
    const copyButton = qs("#btn-copy-from-order");
    
    if (!copyButton) return;
    
    if (!encounterId || encounterId.trim() === "") {
      copyButton.style.backgroundColor = "#95a5a6";
      copyButton.style.color = "#ffffff";
      copyButton.style.cursor = "not-allowed";
      copyButton.title = "Encounter ID harus diisi terlebih dahulu";
      copyButton.innerHTML = "⚠️ Copy dari Order (Encounter ID Required)";
    } else {
      copyButton.style.backgroundColor = "";
      copyButton.style.color = "";
      copyButton.style.cursor = "";
      copyButton.title = "Copy data dari form order ke service request";
      copyButton.innerHTML = "✅ Copy dari Order";
    }
  }

  /**
   * Event Handlers
   */

  /**
   * Handle login
   */
  async handleLogin(e) {
    e?.preventDefault?.();

    try {
      const username = getValue("#username")?.trim();
      const password = getValue("#password");

      if (!username || !password) {
        showToast(MESSAGES.ERROR.LOGIN_FIELDS_REQUIRED, "error");
        return;
      }

      State.app.setLoading(true);

      const result = await this.modules.auth.login(username, password);

      if (result.success) {
        showToast(MESSAGES.SUCCESS.LOGIN_SUCCESS, "success");

        // Clear login form
        setValue("#username", "");
        setValue("#password", "");
      } else {
        showToast(result.error || MESSAGES.ERROR.LOGIN_FAILED, "error");
      }
    } catch (error) {
      console.error("Login error:", error);
      showToast(MESSAGES.ERROR.LOGIN_FAILED, "error");
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Handle logout
   */
  async handleLogout(e) {
    e?.preventDefault?.();

    try {
      await this.modules.auth.logout();
      showToast(MESSAGES.SUCCESS.LOGOUT_SUCCESS, "success");
    } catch (error) {
      console.error("Logout error:", error);
      showToast(MESSAGES.ERROR.LOGOUT_FAILED, "error");
    }
  }

  /**
   * Handle order submission
   */
  async handleOrderSubmit(e) {
    e?.preventDefault?.();

    try {
      // Validate form
      const formData = this.modules.forms.getData("order-form");
      const validation =
        this.modules.validation.schemas.orderForm.validate(formData);

      if (!validation.isValid) {
        this.displayValidationErrors(validation.errors);
        return;
      }

      // Apply business rules
      const businessValidation = this.validateBusinessRules(formData);
      if (!businessValidation.isValid) {
        this.displayValidationErrors(businessValidation.errors);
        return;
      }

      State.app.setLoading(true);

      // Collect payload
      const payload = this.collectOrderPayload(formData);

      // Submit order
      const result = await OrdersApi.createOrder(payload);

      if (result.success) {
        showToast(MESSAGES.SUCCESS.ORDER_CREATED, "success");

        // Display result
        this.displayOrderResult(result.data);

        // Clear form
        this.modules.forms.reset("order-form");
      } else {
        throw new Error(result.error);
      }
    } catch (error) {
      console.error("Order submission error:", error);
      showToast(
        MESSAGES.ERROR.ORDER_CREATION_FAILED + ": " + error.message,
        "error"
      );
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Handle service request creation
   */
  async handleServiceRequestCreate(e) {
    e?.preventDefault?.();

    try {
      // Validate form
      const formData = this.modules.forms.getData("service-request-form");
      const validation =
        this.modules.validation.schemas.serviceRequest.validate(formData);

      if (!validation.isValid) {
        this.displayValidationErrors(validation.errors);
        return;
      }

      State.app.setLoading(true);

      // Collect payload
      const payload = this.collectServiceRequestPayload(formData);

      // Create service request
      const result = await SatusehatApi.createServiceRequest(payload);

      if (result.success) {
        showToast(MESSAGES.SUCCESS.SERVICE_REQUEST_CREATED, "success");

        // Save to database
        await this.saveServiceRequestToDatabase(result.data);

        // Display result
        this.displayServiceRequestResult(result.data);

        // Clear form
        this.modules.forms.reset("service-request-form");
      } else {
        throw new Error(result.error);
      }
    } catch (error) {
      console.error("Service request creation error:", error);
      showToast(
        MESSAGES.ERROR.SERVICE_REQUEST_CREATION_FAILED + ": " + error.message,
        "error"
      );
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Handle sim order actions
   */
  async handleSimOrderActions(e) {
    const target = e.target;
    const action = target.dataset.action;
    const orderId = target.dataset.orderId;

    if (!action || !orderId) return;

    try {
      State.app.setLoading(true);

      switch (action) {
        case "use":
          await this.useSimOrder(orderId);
          break;
        case "send":
          await this.sendSimOrderById(orderId);
          break;
        case "update":
          await this.updateSimOrderById(orderId);
          break;
        case "delete":
          await this.deleteSimOrderById(orderId);
          break;
        default:
          console.warn("Unknown action:", action);
      }
    } catch (error) {
      console.error("Sim order action error:", error);
      showToast("Gagal melakukan aksi: " + error.message, "error");
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Handle patient search
   */
  async handlePatientSearch(e) {
    e?.preventDefault?.();

    try {
      const query = getValue("#patient-search-input")?.trim();
      if (!query || query.length < 2) {
        showToast("Masukkan minimal 2 karakter untuk pencarian", "warning");
        return;
      }

      State.app.setLoading(true);

      const result = await SatusehatApi.searchPatients(query);

      if (result.success) {
        this.renderPatientSearchResults(result.data);
        this.modules.modals.open("patient-search-modal");
      } else {
        throw new Error(result.error);
      }
    } catch (error) {
      console.error("Patient search error:", error);
      showToast("Gagal mencari pasien: " + error.message, "error");
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Handle practitioner search
   */
  async handlePractitionerSearch(e) {
    e?.preventDefault?.();

    try {
      const query = getValue("#practitioner-search-input")?.trim();
      if (!query || query.length < 2) {
        showToast("Masukkan minimal 2 karakter untuk pencarian", "warning");
        return;
      }

      State.app.setLoading(true);

      const result = await SatusehatApi.searchPractitioners(query);

      if (result.success) {
        this.renderPractitionerSearchResults(result.data);
        this.modules.modals.open("practitioner-search-modal");
      } else {
        throw new Error(result.error);
      }
    } catch (error) {
      console.error("Practitioner search error:", error);
      showToast("Gagal mencari dokter: " + error.message, "error");
    } finally {
      State.app.setLoading(false);
    }
  }

  /**
   * Handle SIM order selection from table
   */
  handleSimOrderSelect(selectedData) {
    try {
      if (selectedData && selectedData.id) {
        State.app.setActiveOrder(selectedData);
        showToast("Order dipilih: " + selectedData.id, "success");
      }
    } catch (error) {
      console.error("SIM order selection error:", error);
      showToast("Gagal memilih order: " + error.message, "error");
    }
  }

  /**
   * Handle patient selection from table
   */
  handlePatientSelect(selectedData) {
    try {
      if (selectedData) {
        // Fill patient form fields
        setValue("#patient-ihs-number", selectedData.ihsNumber || "");
        setValue("#patient-national-id", selectedData.nationalId || "");
        setValue("#patient-name", selectedData.name || "");
        setValue("#patient-sex", selectedData.sex || "");
        setValue("#patient-birth-date", selectedData.birthDate || "");

        showToast("Data pasien dipilih", "success");
        this.modules.modals.close("patient-search-modal");
      }
    } catch (error) {
      console.error("Patient selection error:", error);
      showToast("Gagal memilih pasien: " + error.message, "error");
    }
  }

  /**
   * Handle practitioner selection from table
   */
  handlePractitionerSelect(selectedData) {
    try {
      if (selectedData) {
        // Fill practitioner form fields
        setValue("#practitioner-ihs-number", selectedData.ihsNumber || "");
        setValue("#practitioner-name", selectedData.name || "");
        setValue("#practitioner-nik", selectedData.nik || "");

        showToast("Data dokter dipilih", "success");
        this.modules.modals.close("practitioner-search-modal");
      }
    } catch (error) {
      console.error("Practitioner selection error:", error);
      showToast("Gagal memilih dokter: " + error.message, "error");
    }
  }

  /**
   * Handle patient autocomplete selection
   */
  handlePatientAutocomplete(selectedData) {
    try {
      if (selectedData) {
        setValue("#patient-name", selectedData.name || selectedData.text || "");
        if (selectedData.ihsNumber)
          setValue("#patient-ihs-number", selectedData.ihsNumber);
        if (selectedData.nationalId)
          setValue("#patient-national-id", selectedData.nationalId);

        showToast("Pasien dipilih dari autocomplete", "success");
      }
    } catch (error) {
      console.error("Patient autocomplete error:", error);
      showToast("Gagal memilih pasien: " + error.message, "error");
    }
  }

  /**
   * Handle practitioner autocomplete selection
   */
  handlePractitionerAutocomplete(selectedData) {
    try {
      if (selectedData) {
        setValue(
          "#practitioner-name",
          selectedData.name || selectedData.text || ""
        );
        if (selectedData.ihsNumber)
          setValue("#practitioner-ihs-number", selectedData.ihsNumber);
        if (selectedData.nik) setValue("#practitioner-nik", selectedData.nik);

        showToast("Dokter dipilih dari autocomplete", "success");
      }
    } catch (error) {
      console.error("Practitioner autocomplete error:", error);
      showToast("Gagal memilih dokter: " + error.message, "error");
    }
  }

  /**
   * Handle form validation
   */
  handleFormValidation(e) {
    const field = e.target;
    const fieldName = field.name || field.id;
    const value = field.value;

    // Get appropriate validation schema
    let schema;
    if (field.closest("#order-form")) {
      schema = ValidationSchemas.orderForm;
    } else if (field.closest("#service-request-form")) {
      schema = ValidationSchemas.serviceRequest;
    } else if (field.closest("#patient-registration-form")) {
      schema = ValidationSchemas.patientRegistration;
    }

    if (schema) {
      const validation = schema.validate({ [fieldName]: value }, fieldName);
      this.displayFieldValidation(field, validation);
    }
  }

  /**
   * Handle schedule change
   */
  handleScheduleChange() {
    // Auto-generate registration number
    this.autoGenerateRegistrationOnScheduleChange();

    // Validate H-7 selection
    this.validateHMinus7Selection();
  }

  /**
   * Handle service type change
   */
  handleServiceTypeChange() {
    // Auto-generate registration number
    this.autoGenerateRegistrationOnScheduleChange();
  }

  /**
   * Utility Methods
   */

  /**
   * Load SATUSEHAT locations
   */
  async loadSatusehatLocations() {
    try {
      // Check cache first
      const cachedLocations = LocationCache.getLocations();
      if (cachedLocations.length > 0 && !LocationCache.isExpired()) {
        State.data.setLocations(cachedLocations);
        this.populateLocationDropdown(cachedLocations);
        return;
      }

      const result = await SatusehatApi.fetchLocations();

      if (result.success) {
        State.data.setLocations(result.data);
        this.populateLocationDropdown(result.data);
        LocationCache.setLocations(result.data);
      } else {
        throw new Error(result.error);
      }
    } catch (error) {
      console.error("Failed to load SATUSEHAT locations:", error);

      // Try to use cached data even if expired
      const cachedLocations = LocationCache.getLocations();
      if (cachedLocations.length > 0) {
        State.data.setLocations(cachedLocations);
        this.populateLocationDropdown(cachedLocations);
        showToast(
          "Menggunakan data lokasi cache (mungkin tidak terbaru)",
          "warning"
        );
      } else {
        showToast("Gagal memuat data lokasi", "error");
      }
    }
  }

  /**
   * Load procedure catalog
   */
  async loadProcedureCatalog() {
    try {
      const result = await StaticDataApi.loadAll();

      if (result.success) {
        const procedures = result.data.procedures || [];
        State.data.setProcedures(procedures);
        this.renderProcedureCatalog(procedures);
      } else {
        throw new Error(result.error);
      }
    } catch (error) {
      console.error("Failed to load procedure catalog:", error);
      showToast("Gagal memuat katalog prosedur", "error");
    }
  }

  /**
   * Load cached suggestions
   */
  loadCachedSuggestions() {
    try {
      const suggestions = SuggestionsCache.getAllSuggestions();
      State.data.setSuggestions("all", suggestions);

      // Populate datalists
      Object.entries(suggestions).forEach(([key, values]) => {
        const datalist = qs(`#${key}-suggestions`);
        if (datalist && values.length > 0) {
          datalist.innerHTML = values
            .map((value) => `<option value="${value}"></option>`)
            .join("");
        }
      });
    } catch (error) {
      console.error("Failed to load cached suggestions:", error);
    }
  }

  /**
   * Populate location dropdown
   * @param {Array} items - Array of location items
   */
  populateLocationDropdown(items) {
    const sel = qs("#sr_location_id");
    if (!sel) return;

    const current = sel.value;
    sel.innerHTML =
      '<option value="">-- pilih lokasi --</option>' +
      (items || [])
        .map((it) => `<option value="${it.id}">${it.name} (${it.id})</option>`)
        .join("");

    if (current) sel.value = current;
  }

  /**
   * Render procedure catalog
   * @param {Array} list - Array of procedure items
   */
  renderProcedureCatalog(list) {
    let items = Array.isArray(list) ? list : window.PROCEDURE_SAMPLES || [];

    if (!items.length && window.LOINC_LABELS) {
      items = Object.entries(window.LOINC_LABELS).map(
        ([code, display], idx) => ({
          no: idx + 1,
          name: display,
          type: "LOINC",
          code,
          display,
          modality: "",
        })
      );
    }

    const tbody = qs("#procedure-results");
    if (!tbody) return;

    if (!items.length) {
      tbody.innerHTML = '<tr><td colspan="5">Tidak ada data</td></tr>';
      return;
    }

    tbody.innerHTML = items
      .map((it) => {
        const no = it.no ?? "";
        const name = it.name ?? it.display ?? "";
        const type = it.type ?? "";
        const code = it.code ?? "";
        const display = it.display ?? "";
        const modality = it.modality ?? "";
        return (
          `<tr data-code="${code}" data-name="${name}" data-modality="${modality}">` +
          `<td>${no}</td><td>${name}</td><td>${type}</td><td>${code}</td><td>${display}</td>` +
          `</tr>`
        );
      })
      .join("");

    // Add click handlers for procedure selection
    Array.from(tbody.querySelectorAll("tr")).forEach((tr) => {
      tr.ondblclick = () => {
        const d = tr.dataset;
        const setVal = (sel, val) => {
          const el = qs(sel);
          if (el) el.value = val || "";
        };

        setVal("#sr_code", d.code);
        setVal("#sr_code_display", d.name || d.code);
        if (d.modality) setVal("#modality", d.modality);

        const modal = qs("#procedure-search-modal");
        if (modal) modal.hidden = true;

        showToast("Tindakan dipilih", "success");
      };
    });
  }

  /**
   * Load user-specific data
   */
  async loadUserData() {
    try {
      // Load sim orders
      await this.loadSimOrders();

      // Load other user-specific data as needed
    } catch (error) {
      console.error("Failed to load user data:", error);
    }
  }

  /**
   * Clear user data
   */
  clearUserData() {
    // Clear state
    State.data.setOrders([]);
    State.data.setActiveOrder(null);

    // Clear forms
    this.modules.forms.resetAll();

    // Clear tables
    this.modules.tables.clearAll();
  }

  /**
   * Validate business rules
   */
  validateBusinessRules(formData) {
    const results = [
      BusinessRules.validatePatientAge(formData),
      BusinessRules.validateWorkingHours(formData),
      BusinessRules.validateWeekendScheduling(formData),
    ];

    return ValidationUtils.combineResults(results);
  }

  /**
   * Display validation errors
   */
  displayValidationErrors(errors) {
    Object.entries(errors).forEach(([fieldName, message]) => {
      const field = qs(`#${fieldName}`) || qs(`[name="${fieldName}"]`);
      if (field) {
        this.displayFieldValidation(field, { isValid: false, error: message });
      }
    });

    const firstError = Object.values(errors)[0];
    showToast(firstError, "error");
  }

  /**
   * Display field validation
   */
  displayFieldValidation(field, validation) {
    if (validation.isValid) {
      field.style.borderColor = "";
      field.style.backgroundColor = "";
    } else {
      field.style.borderColor = "#e74c3c";
      field.style.backgroundColor = "#fdf2f2";

      // Clear error styling after 3 seconds
      setTimeout(() => {
        field.style.borderColor = "";
        field.style.backgroundColor = "";
      }, 3000);
    }
  }

  /**
   * Collect order payload
   */
  collectOrderPayload(formData) {
    return {
      patient_id: formData.patient_id,
      practitioner_id: formData.practitioner_id,
      procedure_code: formData.procedure_code,
      scheduled_date: formData.scheduled_date,
      scheduled_time: formData.scheduled_time,
      notes: formData.notes || "",
      registration_number: formData.registration_number || "",
      service_type: formData.service_type || "RJ",
    };
  }

  /**
   * Collect service request payload
   */
  collectServiceRequestPayload(formData) {
    return {
      patient_id: formData.patient_id,
      practitioner_id: formData.practitioner_id,
      location_id: formData.location_id,
      procedure_code: formData.procedure_code,
      scheduled_date: formData.scheduled_date,
      scheduled_time: formData.scheduled_time,
      notes: formData.notes || "",
    };
  }

  /**
   * Save service request to database
   */
  async saveServiceRequestToDatabase(serviceRequestData) {
    try {
      const activeOrder = State.getState("data.activeOrder");
      if (!activeOrder) {
        console.warn("No active order found, skipping database save");
        return;
      }

      const serviceRequestId =
        serviceRequestData?.id || serviceRequestData?.resourceId || "";
      if (!serviceRequestId) {
        console.warn(
          "No service request ID found in response, skipping database save"
        );
        return;
      }

      const result = await OrdersApi.updateServiceRequestId(
        activeOrder.id,
        serviceRequestId
      );

      if (result.success) {
        showToast(MESSAGES.SUCCESS.SERVICE_REQUEST_SAVED, "success");
      } else {
        showToast(MESSAGES.WARNING.SERVICE_REQUEST_SAVE_FAILED, "warning");
      }
    } catch (error) {
      console.error("Error saving service request ID to database:", error);
      showToast(MESSAGES.WARNING.SERVICE_REQUEST_SAVE_FAILED, "warning");
    }
  }

  /**
   * Additional methods would continue here...
   * (Due to length constraints, I'm showing the core structure)
   * The remaining methods would be refactored similarly using the modular approach
   */

  /**
   * Copy data from order form to service request form
   */
  copyFromOrderToServiceRequest() {
    try {
      // Check available data in order form first
      const availableData = {
        patientId: qs("#ihs_number")?.value || "",
        encounterId: qs("#satusehat_encounter_id")?.value || "",
        practitionerId: qs("#satusehat_practitioner_id")?.value || "",
        locationId: qs("#satusehat_location_id")?.value || "",
        procedureCode: qs("#procedure_code")?.value || "",
        procedureName: qs("#procedure_name")?.value || "",
        clinicalNotes: qs("#clinical_notes")?.value || "",
      };

      // VALIDASI WAJIB: Encounter ID harus ada
      if (
        !availableData.encounterId ||
        availableData.encounterId.trim() === ""
      ) {
        // Highlight encounter ID field dengan warna merah
        const encounterField = qs("#satusehat_encounter_id");
        if (encounterField) {
          encounterField.style.borderColor = "#e74c3c";
          encounterField.style.backgroundColor = "#fdf2f2";
          encounterField.focus();

          // Reset styling setelah 5 detik
          setTimeout(() => {
            encounterField.style.borderColor = "";
            encounterField.style.backgroundColor = "";
          }, 5000);
        }

        showToast(
          "❌ Tidak dapat menyalin data: Encounter ID harus diisi terlebih dahulu di form Order!",
          "error"
        );
        return;
      }

      // Copy patient data - menggunakan ihs_number sebagai patient FHIR ID
      const patientId = availableData.patientId;
      if (patientId) setValue("#sr_patient_id", patientId);

      // Copy encounter data
      const encounterId = availableData.encounterId;
      if (encounterId) setValue("#sr_encounter_id", encounterId);

      // Copy practitioner data - menggunakan satusehat_practitioner_id
      const practitionerId = availableData.practitionerId;
      if (practitionerId) setValue("#sr_practitioner_id", practitionerId);

      // Copy location data
      const locationId = availableData.locationId;
      if (locationId) setValue("#sr_location_id", locationId);

      // Copy procedure data
      const procedureCode = availableData.procedureCode;
      const procedureName = availableData.procedureName;
      if (procedureCode) setValue("#sr_code", procedureCode);
      if (procedureName) setValue("#sr_code_display", procedureName);

      // Copy additional data from order form
      const clinicalNotes = availableData.clinicalNotes;

      // Set notes with clinical notes if available
      if (clinicalNotes) {
        setValue("#sr_note", clinicalNotes);
      }

      // Set default authored_on to current time
      const now = new Date();
      const localDateTime = new Date(
        now.getTime() - now.getTimezoneOffset() * 60000
      )
        .toISOString()
        .slice(0, 16);
      setValue("#sr_authored_on", localDateTime);

      // Show summary of copied data
      const copiedFields = [];
      if (patientId) copiedFields.push("Patient ID");
      if (encounterId) copiedFields.push("Encounter ID");
      if (practitionerId) copiedFields.push("Practitioner ID");
      if (locationId) copiedFields.push("Location ID");
      if (procedureCode) copiedFields.push("Procedure Code");
      if (procedureName) copiedFields.push("Procedure Name");
      if (clinicalNotes) copiedFields.push("Clinical Notes");

      // Visual feedback - highlight copied fields
      const highlightFields = [
        { id: "#sr_patient_id", copied: !!patientId },
        { id: "#sr_encounter_id", copied: !!encounterId },
        { id: "#sr_practitioner_id", copied: !!practitionerId },
        { id: "#sr_location_id", copied: !!locationId },
        { id: "#sr_code", copied: !!procedureCode },
        { id: "#sr_code_display", copied: !!procedureName },
        { id: "#sr_note", copied: !!clinicalNotes },
      ];

      highlightFields.forEach((field) => {
        const element = qs(field.id);
        if (element) {
          if (field.copied) {
            element.style.borderColor = "#2ecc71";
            element.style.backgroundColor = "#d5f4e6";
            setTimeout(() => {
              element.style.borderColor = "";
              element.style.backgroundColor = "";
            }, 2000);
          }
        }
      });

      if (copiedFields.length > 0) {
        showToast(
          `Data berhasil disalin: ${copiedFields.join(", ")}`,
          "success"
        );
      } else {
        showToast(
          "Tidak ada data yang dapat disalin dari order. Pastikan form order sudah diisi.",
          "error"
        );
      }
    } catch (err) {
      console.error("Error copying from order:", err);
      showToast(
        "Gagal menyalin data dari order: " + (err?.message || err),
        "error"
      );
    }
  }

  /**
   * Save simulation order
   */
  async saveSimOrder(e) {
    try {
      e?.preventDefault?.();
    } catch (_) {}

    // Validate H-7 selection first
    if (!this.validateHMinus7Selection()) return;

    const payload = this.collectOrderPayload();
    const record = this.collectSimOrderRecord(payload);
    const base = apiService.baseUrl;
    const activeId = getValue("#active_sim_order_id")?.trim();
    const isEdit = !!activeId;
    const url = isEdit
      ? `${base}/sim/orders/${encodeURIComponent(activeId)}`
      : `${base}/sim/orders`;

    const btn = qs("#btn-save-sim-order");
    if (btn) {
      btn.disabled = true;
      btn.textContent = isEdit ? "Mengubah..." : "Menyimpan...";
    }

    try {
      const res = await fetch(url, {
        method: isEdit ? "PATCH" : "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(record),
      });

      const data = await res.json().catch(() => ({}));
      this.state.lastResult = data;

      const resultEl = qs("#result-json");
      const resultCard = qs("#result-card");
      if (resultEl) resultEl.textContent = JSON.stringify(data, null, 2);
      if (resultCard) resultCard.hidden = false;

      const actionMsg = isEdit
        ? "Order simulasi diperbarui"
        : "Order simulasi disimpan";

      showToast(
        res.ok
          ? actionMsg
          : "Gagal simpan: " + (data?.detail || res.statusText),
        res.ok ? "success" : "error"
      );

      try {
        await this.loadSimOrders();
      } catch (_) {}
    } catch (err) {
      console.error("Simpan order error:", err);
      showToast("Gagal menyimpan order: " + (err?.message || err), "error");
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = "Simpan Order";
      }
    }
  }

