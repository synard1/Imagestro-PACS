# The /orders/<identifier>/files endpoints (GET/POST/DELETE/content) are implemented
# once in the "ORDER FILES CRUD" section below to avoid duplicate view functions.


@app.route('/orders/<identifier>/satusehat-status', methods=['GET'])
def get_order_satusehat_status(identifier):
    """
    Get concise SatuSehat status info for a specific order.

    Identifier:
      - UUID id, atau
      - accession_number, atau
      - order_number

    Hanya mengembalikan order dengan status != 'DELETED'.

    Contoh output:
      {
        "status": "success",
        "order_id": "...",
        "order_number": "ORD2025111000001",
        "accession_number": "ACC20251110000123",
        "satusehat_synced": true,
        "satusehat_sync_date": "2025-11-10T07:20:30Z",
        "satusehat_service_request_id": "abcd-1234",
        "order_status": "SYNCED",
        "last_updated": "2025-11-10T07:20:30Z",
        "satusehat_sync_details": {
          "status": "success",
          "service_request_id": "abcd-1234",
          "ihs_number": "...",
          "encounter_id": "...",
          "synced_at": "2025-11-10T07:20:30Z",
          "upstream": {
            "status": 201,
            "x_request_id": "...",
            "url": "..."
          }
        },
        "updated_audit": {
          "by": "admin@example.com",
          "at": "2025-11-10T07:20:30Z",
          "action": "SATUSEHAT_SYNC"
        }
      }
    """
    try:
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)

            # Resolve order by id / accession_number / order_number
            try:
                uuid_obj = uuid.UUID(identifier)
                cursor.execute("""
                    SELECT *
                    FROM orders
                    WHERE id = %s AND status != 'DELETED'
                """, (str(uuid_obj),))
            except ValueError:
                cursor.execute("""
                    SELECT *
                    FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                      AND status != 'DELETED'
                """, (identifier, identifier))

            order = cursor.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            # Normalisasi id
            if order.get('id') is not None:
                order_id = str(order['id'])
            else:
                order_id = None

            # Ambil blok details jika ada
            details = order.get('details')
            if isinstance(details, dict):
                satusehat_sync_details = details.get('satusehat_sync')
                updated_audit = details.get('updated')
            else:
                satusehat_sync_details = None
                updated_audit = None

            resp = {
                "status": "success",
                "order_id": order_id,
                "order_number": order.get('order_number'),
                "accession_number": order.get('accession_number'),
                "satusehat_synced": order.get('satusehat_synced'),
                "satusehat_sync_date": order.get('satusehat_sync_date'),
                "satusehat_service_request_id": order.get('satusehat_service_request_id'),
                "order_status": order.get('order_status') or order.get('status'),
                "last_updated": order.get('updated_at'),
                "satusehat_sync_details": satusehat_sync_details,
                "updated_audit": updated_audit
            }

            return jsonify(resp), 200

    except Exception as e:
        logger.error(f"Error getting SatuSehat status for order {identifier}: {str(e)}", exc_info=True)
        return jsonify({
            "status": "error",
            "message": "Failed to get SatuSehat status for order",
            "detail": str(e)
        }), 500

@app.route('/orders/<identifier>/sync-satusehat', methods=['POST'])
def sync_to_satusehat(identifier):
    """Sync order ke SATUSEHAT (buat ServiceRequest nyata)"""
    try:
        # Ambil order
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)
            try:
                uuid_obj = uuid.UUID(identifier)
                cursor.execute("SELECT * FROM orders WHERE id = CAST(%s AS UUID)", (str(uuid_obj),))
            except ValueError:
                cursor.execute("SELECT * FROM orders WHERE accession_number = %s", (identifier,))
            order = cursor.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

        body = request.get_json(silent=True) or {}
        # Patient & Encounter dari SATUSEHAT harus tersedia (real id)
        satusehat_ihs_number = (
            body.get('satusehat_ihs_number')
            or body.get('satusehat_patient_id')
            or body.get('patientId')
            or body.get('ihs_number')
            or order.get('satusehat_ihs_number')
        )
        encounter_id = body.get('satusehat_encounter_id') or body.get('encounterId') or order.get('satusehat_encounter_id')
        if not satusehat_ihs_number:
            return jsonify({
                "status": "error",
                "message": "satusehat_ihs_number diperlukan (isi di body atau simpan di order)."
            }), 400
        if not encounter_id:
            return jsonify({
                "status": "error",
                "message": "satusehat_encounter_id diperlukan (isi di body atau simpan di order)."
            }), 400

        # LOINC/procedure code
        loinc_code = body.get('loinc_code') or body.get('procedure_code') or order.get('procedure_code')
        if not loinc_code:
            return jsonify({
                "status": "error",
                "message": "procedure_code/loinc_code tidak ditemukan. Harap isi dengan kode LOINC yang valid."
            }), 400

        requester_ref = body.get('requester_ref') or SATUSEHAT_REQUESTER_REF
        performer_ref = body.get('performer_ref') or SATUSEHAT_PERFORMER_REF

        # Siapkan payload ServiceRequest
        accession_number = order['accession_number']
        identifier_system = f"{ACSN_SYSTEM_BASE.rstrip('/')}/{SATUSEHAT_ORG_ID}"
        sr = {
            "resourceType": "ServiceRequest",
            "status": "active",
            "intent": "order",
            "code": {"coding": [{"system": "http://loinc.org", "code": loinc_code}]},
            "subject": {"reference": f"Patient/{satusehat_ihs_number}"},
            "encounter": {"reference": f"Encounter/{encounter_id}"},
            "identifier": [{"system": identifier_system, "value": accession_number}],
            "authoredOn": now_utc_fhir()
        }
        notes = order.get('clinical_notes') or order.get('clinical_indication')
        if notes:
            sr["note"] = [{"text": notes}]
        if requester_ref:
            sr["requester"] = {"reference": requester_ref}
        if performer_ref:
            sr["performer"] = [{"reference": performer_ref}]

        # Token & submit ke FHIR
        token = get_satusehat_token()
        url = f"{SATUSEHAT_FHIR_BASE}/ServiceRequest"
        headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/fhir+json"}
        resp = requests.post(url, json=sr, headers=headers, timeout=45)
        # Simpan upstream info untuk debug
        upstream = {
            "status": resp.status_code,
            "x_request_id": resp.headers.get("x-request-id"),
            "url": url
        }
        if resp.status_code >= 300:
            try:
                js = resp.json()
            except Exception:
                js = None
            return jsonify({
                "status": "error",
                "message": summarize_operation_outcome(js) or (resp.text[:1000] if resp.text else "<empty body>"),
                "upstream": upstream,
                "sent": sr
            }), 502

        sr_id = resp.json().get('id')

        # Siapkan metadata audit & detail sync SATUSEHAT di kolom details
        try:
            actor_info = resolve_request_actor()
        except Exception as actor_err:
            logger.warning(f"resolve_request_actor error in sync_to_satusehat: {actor_err}")
            actor_info = {}

        if not isinstance(actor_info, dict):
            actor_info = {}

        actor_id = (
            actor_info.get('id')
            or actor_info.get('username')
            or request.headers.get('X-User-ID')
            or 'system'
        )
        actor_username = actor_info.get('username')
        actor_display = actor_username or actor_id or 'system'

        # existing details + pastikan struktur created/updated/deleted rapi
        updated_details = ensure_audit_structure(order.get('details'), order.get('created_at'))

        # Simpan jejak khusus untuk operasi sync SATUSEHAT
        # Field ini yang nanti dibaca dashboard UI.
        updated_details['satusehat_sync'] = {
            "status": "success",
            "service_request_id": sr_id,
            "ihs_number": satusehat_ihs_number,
            "encounter_id": encounter_id,
            "synced_at": utc_now_iso(),
            "upstream": upstream
        }

        # Update blok "updated" umum sebagai audit siapa yang terakhir ubah
        updated_details['updated'] = {
            "by": actor_display,
            "at": utc_now_iso(),
            "action": "SATUSEHAT_SYNC"
        }

        with get_db_connection() as conn:
            cursor = conn.cursor()
            cursor.execute(
                """
                UPDATE orders 
                SET satusehat_ihs_number = %s,
                    satusehat_encounter_id = %s,
                    satusehat_service_request_id = %s,
                    satusehat_synced = TRUE,
                    satusehat_sync_date = CURRENT_TIMESTAMP,
                    order_status = 'SYNCED',
                    updated_at = CURRENT_TIMESTAMP,
                    details = %s
                WHERE id = %s
                """,
                (satusehat_ihs_number, encounter_id, sr_id, Json(updated_details), str(order['id']))
            )
            log_order_action(
                order['id'], order['order_number'], order['accession_number'],
                'SATUSEHAT_SYNCED',
                {"status": order['order_status']},
                {"service_request_id": sr_id, "upstream": upstream},
                request.headers.get('X-User-ID', 'system'),
                request.remote_addr
            )

        return jsonify({
            "status": "success",
            "message": "ServiceRequest dibuat di SATUSEHAT",
            "accession_number": accession_number,
            "satusehat_ihs_number": satusehat_ihs_number,
            "satusehat_encounter_id": encounter_id,
            "satusehat_service_request_id": sr_id,
            "upstream": upstream
        }), 200

    except Exception as e:
        logger.error(f"Error syncing to SATUSEHAT: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

@app.route('/orders/<identifier>/create-worklist', methods=['POST'])
def create_worklist_from_order(identifier, jwt_token=None):
    """Create DICOM worklist from order"""
    try:
        # Allow route calls without explicitly passing jwt_token
        if jwt_token is None:
            auth_header = request.headers.get('Authorization')
            if auth_header and auth_header.startswith('Bearer '):
                jwt_token = auth_header.split(' ')[1]
        # Get order
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)
            try:
                uuid_obj = uuid.UUID(identifier)
                cursor.execute("SELECT * FROM orders WHERE id = CAST(%s AS UUID)", (str(uuid_obj),))
            except ValueError:
                cursor.execute("SELECT * FROM orders WHERE accession_number = %s", (identifier,))
            order = cursor.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404
        # Create worklist payload
        scheduled_date = None
        scheduled_time = None
        try:
            scheduled_at = order.get('scheduled_at')
            if scheduled_at:
                dt_val = scheduled_at if isinstance(scheduled_at, datetime) else datetime.fromisoformat(str(scheduled_at).replace('Z', '+00:00'))
                scheduled_date = dt_val.strftime('%Y%m%d')
                scheduled_time = dt_val.strftime('%H%M%S')
        except Exception:
            scheduled_date = None
            scheduled_time = None
        patient_identifier = order.get('patient_national_id') or order.get('patient_id')
        worklist_data = {
            "patient_name": order['patient_name'].replace(' ', '^'),
            "patient_id": patient_identifier,
            "patient_birth_date": order['birth_date'].strftime('%Y%m%d') if order['birth_date'] else None,
            "patient_sex": order['gender'],
            "accession_number": order['accession_number'],
            "procedure_description": order['procedure_description'] or order['procedure_name'],
            "modality": order['modality'],
            "scheduled_date": scheduled_date,
            "scheduled_time": scheduled_time,
            "physician_name": order['ordering_physician_name'].replace(' ', '^') if order['ordering_physician_name'] else None,
            "station_aet": MWL_STATION_AET
        }
        # Call MWL Writer service
        try:
            headers = {'Authorization': f'Bearer {jwt_token}'} if jwt_token else {}
            response = requests.post(
                f"{MWL_SERVICE_URL}/worklist/create",
                json=worklist_data,
                headers=headers,
                timeout=10
            )
            response.raise_for_status()
            mwl_response = response.json()
            # Update order status
            actor_id = request.headers.get('X-User-ID', 'system')
            updated_details = ensure_audit_structure(order.get('details'), order.get('created_at'))
            updated_details['updated'] = {'by': actor_id, 'at': utc_now_iso()}
            with get_db_connection() as conn:
                cursor = conn.cursor()
                cursor.execute(
                    """
                    UPDATE orders 
                    SET worklist_status = 'CREATED',
                        order_status = 'SCHEDULED',
                        updated_at = CURRENT_TIMESTAMP,
                        details = %s
                    WHERE id = %s
                    """,
                    (Json(updated_details), str(order['id']))
                )
                log_order_action(
                    order['id'], order['order_number'], order['accession_number'],
                    'WORKLIST_CREATED',
                    {"status": order['order_status']},
                    mwl_response,
                    request.headers.get('X-User-ID', 'system'),
                    request.remote_addr
                )
            return jsonify({
                "status": "success",
                "message": "Worklist created successfully",
                "accession_number": order['accession_number'],
                "worklist": mwl_response
            }), 200
        except requests.exceptions.RequestException as e:
            logger.error(f"Error calling MWL service: {str(e)}")
            return jsonify({
                "status": "error",
                "message": f"Failed to create worklist: {str(e)}"
            }), 500
    except Exception as e:
        logger.error(f"Error creating worklist: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

@app.route('/orders/complete-flow', methods=['GET'])
def complete_flow_wrong_method():
    """Guard: prevent accidental GET on complete-flow, instruct to use POST"""
    return jsonify({
        "status": "error",
        "message": "Use POST /orders/complete-flow with JSON body"
    }), 405

@app.route('/orders/complete-flow', methods=['POST'])
@require_auth(REQUIRED_PERMISSIONS_OM['complete_flow'])
def complete_flow():
    """Complete flow: Create order → Sync SATUSEHAT → Create Worklist"""
    try:
        auth_header = request.headers.get('Authorization')
        jwt_token = auth_header.split(' ')[1] if auth_header and auth_header.startswith('Bearer ') else None

        data = request.get_json()
        
        # Step 1: Create order
        order_response = create_order()
        if order_response[1] != 201:
            return order_response
        
        order_data = order_response[0].get_json()
        order_obj = order_data.get('order') or {}
        order_id = order_obj.get('id')
        accession_number = order_obj.get('accession_number')
        if not order_id or not accession_number:
            return jsonify({"status": "error", "message": "Invalid order response from create"}), 500
        
        logger.info(f"Step 1: Order created - {accession_number}")
        
        # Step 2: Sync to SATUSEHAT
        sync_payload = None
        sync_error = None
        sync_response = sync_to_satusehat(order_id)
        resp_obj, resp_status = (
            sync_response if isinstance(sync_response, tuple)
            else (sync_response, getattr(sync_response, 'status_code', 500))
        )
        if resp_status != 200:
            try:
                sync_error = resp_obj.get_json()
            except Exception:
                if hasattr(resp_obj, "get_data"):
                    try:
                        raw_body = resp_obj.get_data(as_text=True)
                    except TypeError:
                        raw_body = resp_obj.get_data()
                        if isinstance(raw_body, bytes):
                            raw_body = raw_body.decode("utf-8", errors="replace")
                    sync_error = {"message": raw_body}
                else:
                    sync_error = {"message": str(resp_obj)}
            logger.warning(f"Step 2 warning: SATUSEHAT sync failed ({resp_status}) - {accession_number} - {sync_error}")
            if not SATUSEHAT_SYNC_OPTIONAL:
                return resp_obj, resp_status
        else:
            sync_payload = resp_obj.get_json()
            logger.info(f"Step 2: SATUSEHAT synced - {accession_number}")
        
        # Step 3: Create worklist
        worklist_response = create_worklist_from_order(order_id, jwt_token)
        if worklist_response[1] != 200:
            return worklist_response
        
        logger.info(f"Step 3: Worklist created - {accession_number}")
        
        return jsonify({
            "status": "success",
            "message": "Complete flow executed successfully",
            "accession_number": accession_number,
            "order": order_obj,
            "satusehat": sync_payload or {"status": "skipped", "error": sync_error} if sync_error else None,
            "worklist": worklist_response[0].get_json(),
            "next_steps": {
                "1": "Simulate scan",
                "2": "DICOM Router will process automatically",
                "3": "ImagingStudy will be created in SATUSEHAT"
            }
        }), 200
        
    except Exception as e:
        logger.error(f"Error in complete flow: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

@app.route('/orders/<identifier>', methods=['DELETE'])
def delete_order(identifier):
    """Delete order by ID, order number, or accession number"""
    try:
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)
            
            # Try UUID first
            try:
                uuid_obj = uuid.UUID(identifier)
                cursor.execute("SELECT * FROM orders WHERE id = %s", (str(uuid_obj),))
            except ValueError:
                # Try accession or order number
                cursor.execute("""
                    SELECT * FROM orders 
                    WHERE (accession_number = %s OR order_number = %s)
                """, (identifier, identifier))
            
            order = cursor.fetchone()

            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            order_details = order.get('details')
            deleted_marker = None
            if isinstance(order_details, dict):
                deleted_marker = order_details.get('deleted')
            elif order_details is not None:
                logger.warning("Order details stored as non-dict value; treating as already deleted safeguard.")

            already_soft_deleted = order.get('status') == 'DELETED' or deleted_marker is not None
            if already_soft_deleted:
                return jsonify({
                    "status": "error",
                    "message": f"Order already soft deleted. Use DELETE /orders/{identifier}/purge to remove it permanently."
                }), 409

            # Soft delete by marking details.deleted
            try:
                actor_info = resolve_request_actor()
            except Exception as actor_err:
                logger.error(f"Error in resolve_request_actor: {actor_err}")
                actor_info = {}

            if not isinstance(actor_info, dict):
                logger.warning(f"resolve_request_actor returned non-dict, using defaults")
                actor_info = {}

            actor_id = actor_info.get('id') or actor_info.get('username') or 'system'

            # Safely get order details and created_at
            order_created_at = order.get('created_at')

            updated_details = ensure_audit_structure(order_details, order_created_at)
            updated_details['deleted'] = {'by': actor_id, 'at': utc_now_iso()}
            
            cursor.execute(
                """
                UPDATE orders 
                SET details = %s,
                    status = 'DELETED',
                    cancel_at = CURRENT_TIMESTAMP,
                    cancel_by = %s,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = %s
                """,
                (Json(updated_details), actor_id, str(order['id']))
            )
            
            log_order_action(
                order['id'], order['order_number'], order['accession_number'],
                'ORDER_DELETED',
                {"previous_status": order['status']},
                None,
                actor_id,
                request.remote_addr
            )
            
            return jsonify({
                "status": "success",
                "message": "Order deleted successfully",
                "order_id": str(order['id']),
                "accession_number": order['accession_number']
            }), 200
            
    except Exception as e:
        logger.error(f"Error deleting order: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

@app.route('/orders/duplicates/auto-cancel', methods=['POST'])
def auto_cancel_duplicates():
    """
    Manually trigger auto-cancel for duplicate orders based on criteria.
    
    Request body:
    {
        "patient_national_id": "string",  // optional
        "medical_record_number": "string", // optional  
        "modality": "string",              // optional
        "procedure_code": "string",        // optional
        "procedure_name": "string",        // optional
        "date": "YYYY-MM-DD",              // optional
        "window_hours": 24,                // optional, default 24
        "keep_newest": true,               // optional, default true
        "dry_run": false                   // optional, default false
    }
    
    Returns list of orders that would be/were canceled.
    """
    try:
        body = request.get_json() or {}
        
        patient_nik = body.get('patient_national_id')
        mrn = body.get('medical_record_number')
        modality = body.get('modality')
        procedure_code = body.get('procedure_code')
        procedure_name = body.get('procedure_name')
        date_filter = body.get('date')
        window_hours = min(max(1, int(body.get('window_hours', 24))), 168)
        keep_newest = body.get('keep_newest', True)
        dry_run = body.get('dry_run', False)
        
        # Validate at least one filter is provided
        if not any([patient_nik, mrn, modality, procedure_code, procedure_name, date_filter]):
            return jsonify({
                "status": "error",
                "message": "At least one filter parameter is required"
            }), 400
        
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)
            
            # Build WHERE conditions
            where_clauses = ["COALESCE(status, '') NOT IN ('DELETED', 'CANCELED', 'CANCELLED', 'VOID')"]
            params = []
            
            if patient_nik:
                where_clauses.append("COALESCE(patient_national_id, '') = %s")
                params.append(patient_nik)
                
            if mrn:
                where_clauses.append("COALESCE(medical_record_number, '') = %s")
                params.append(mrn)
            
            if modality:
                where_clauses.append("COALESCE(modality, '') = %s")
                params.append(modality)
                
            if procedure_code:
                where_clauses.append("COALESCE(procedure_code, '') = %s")
                params.append(procedure_code)
            elif procedure_name:
                where_clauses.append("COALESCE(procedure_name, '') = %s")
                params.append(procedure_name)
            
            if date_filter:
                try:
                    datetime.strptime(date_filter, '%Y-%m-%d')
                    where_clauses.append("DATE(COALESCE(scheduled_at, created_at)) = %s")
                    params.append(date_filter)
                except ValueError:
                    return jsonify({
                        "status": "error",
                        "message": "Invalid date format. Use YYYY-MM-DD."
                    }), 400
            
            where_clauses.append("created_at >= (CURRENT_TIMESTAMP - INTERVAL '%s hours')")
            params.append(window_hours)
            
            where_sql = " AND ".join(where_clauses)
            
            # Find potential duplicates
            cursor.execute(f"""
                WITH ranked_orders AS (
                    SELECT 
                        *,
                        ROW_NUMBER() OVER (
                            PARTITION BY 
                                COALESCE(patient_national_id, medical_record_number),
                                COALESCE(procedure_code, procedure_name),
                                DATE(COALESCE(scheduled_at, created_at))
                            ORDER BY created_at DESC
                        ) as rn
                    FROM orders
                    WHERE {where_sql}
                )
                SELECT * FROM ranked_orders 
                WHERE rn > 1  -- Keep only duplicates (not the newest)
                ORDER BY patient_national_id, procedure_code, created_at DESC
            """, params)
            
            duplicates_to_cancel = cursor.fetchall()
            
            if not duplicates_to_cancel:
                return jsonify({
                    "status": "success",
                    "message": "No duplicate orders found for the given criteria",
                    "canceled_count": 0,
                    "canceled_orders": [],
                    "dry_run": dry_run
                }), 200
            
            canceled_orders = []
            
            if not dry_run:
                # Perform the actual cancellation
                actor_info = resolve_request_actor()
                actor_id = (actor_info.get('id') or actor_info.get('username') or 'system')
                
                for order in duplicates_to_cancel:
                    try:
                        # Update details with deletion info
                        order_details = ensure_audit_structure(order.get('details'), order.get('created_at'))
                        order_details['deleted'] = {
                            'by': actor_id,
                            'at': utc_now_iso(),
                            'reason': 'MANUAL_AUTO_CANCEL'
                        }
                        
                        cursor.execute(
                            """
                            UPDATE orders
                            SET status = 'DELETED',
                                cancel_at = CURRENT_TIMESTAMP,
                                cancel_by = %s,
                                details = %s,
                                updated_at = CURRENT_TIMESTAMP
                            WHERE id = %s
                            """,
                            (actor_id, Json(order_details), str(order['id']))
                        )
                        
                        canceled_info = {
                            'id': str(order['id']),
                            'order_number': order['order_number'],
                            'accession_number': order['accession_number'],
                            'patient_name': order['patient_name'],
                            'modality': order['modality'],
                            'procedure': order['procedure_code'] or order['procedure_name'],
                            'status_before': order['status'],
                            'canceled_at': utc_now_iso(),
                            'canceled_by': actor_id
                        }
                        canceled_orders.append(canceled_info)
                        
                        # Log the cancellation
                        log_order_action(
                            order['id'],
                            order['order_number'],
                            order['accession_number'],
                            'ORDER_MANUALLY_CANCELED_DUPLICATE',
                            {"previous_status": order['status']},
                            {
                                "reason": "MANUAL_AUTO_CANCEL",
                                "criteria": {
                                    "patient_nik": patient_nik,
                                    "mrn": mrn,
                                    "modality": modality,
                                    "procedure_code": procedure_code,
                                    "procedure_name": procedure_name,
                                    "date": date_filter
                                }
                            },
                            actor_id,
                            request.remote_addr
                        )
                        
                    except Exception as e:
                        logger.error(f"Failed to cancel duplicate order {order['id']}: {e}")
                        continue
                
                conn.commit()
            
            return jsonify({
                "status": "success",
                "message": f"Processed {len(canceled_orders)} duplicate orders",
                "canceled_count": len(canceled_orders),
                "canceled_orders": canceled_orders,
                "dry_run": dry_run,
                "criteria": {
                    "patient_national_id": patient_nik,
                    "medical_record_number": mrn,
                    "modality": modality,
                    "procedure_code": procedure_code,
                    "procedure_name": procedure_name,
                    "date": date_filter,
                    "window_hours": window_hours,
                    "keep_newest": keep_newest
                }
            }), 200
            
    except Exception as e:
        logger.error(f"Error in auto-cancel duplicates: {str(e)}", exc_info=True)
        return jsonify({
            "status": "error",
            "message": "Failed to process auto-cancel duplicates",
            "detail": str(e)
        }), 500


@app.route('/orders/<identifier>/purge', methods=['DELETE'])
def purge_order(identifier):
    """Hard delete order from database. Intended for use after a soft delete."""
    try:
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)

            # Try UUID first
            try:
                uuid_obj = uuid.UUID(identifier)
                cursor.execute("SELECT * FROM orders WHERE id = %s", (str(uuid_obj),))
            except ValueError:
                cursor.execute("""
                    SELECT * FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                """, (identifier, identifier))

            order = cursor.fetchone()

            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            try:
                actor_info = resolve_request_actor()
            except Exception as actor_err:
                logger.error(f"Error in resolve_request_actor: {actor_err}")
                actor_info = {}

            if not isinstance(actor_info, dict):
                logger.warning("resolve_request_actor returned non-dict, using defaults")
                actor_info = {}

            actor_id = actor_info.get('id') or actor_info.get('username') or 'system'

            cursor.execute(
                "DELETE FROM orders WHERE id = %s",
                (str(order['id']),)
            )

            if cursor.rowcount == 0:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            log_order_action(
                order['id'], order['order_number'], order['accession_number'],
                'ORDER_PURGED',
                {"previous_status": order.get('status')},
                None,
                actor_id,
                request.remote_addr
            )

            return jsonify({
                "status": "success",
                "message": "Order purged successfully",
                "order_id": str(order['id']),
                "accession_number": order['accession_number']
            }), 200

    except Exception as e:
        logger.error(f"Error purging order: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

# Add new endpoint for updating orders
@app.route('/orders/<identifier>', methods=['PUT'])
def update_order(identifier):
    """
    Partially update an order.

    Request identifier:
      - id (UUID), or
      - accession_number, or
      - order_number

    Rules:
      - Protected fields cannot be updated.
      - Unknown/unsupported fields cause 400 with explanation.
      - Some common aliases are mapped to canonical columns.
      - JSON fields are stored properly.
    """
    try:
        body = request.get_json(silent=True) or {}

        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)

            # Resolve target order
            try:
                uuid_obj = uuid.UUID(identifier)
                cursor.execute("SELECT * FROM orders WHERE id = %s", (str(uuid_obj),))
            except ValueError:
                cursor.execute(
                    """
                    SELECT * FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                    """,
                    (identifier, identifier),
                )

            order = cursor.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            old_status = (order.get('status') or '').upper()

            # Fields that must never be updated directly via this endpoint
            protected_fields = {
                'id',
                'order_number',
                'accession_number',
                'created_at',
                'updated_at',
                'satusehat_service_request_id',
                'order_source',
            }

            # Aliases from client payload -> canonical column names
            alias_map = {
                'requested_procedure': 'procedure_name',
                'station_ae_title': 'ordering_station_aet',
                'scheduled_start_at': 'scheduled_at',
                # accession_no is intentionally NOT mapped for update safety
            }

            # Known JSON/JSONB columns that should use psycopg2.extras.Json
            json_fields = {
                'details',
                'metadata',  # if column exists
            }

            update_clauses = []
            params = []
            invalid_fields = []

            # Lifecycle status (use global helpers)
            requested_status = None

            for raw_key, value in body.items():
                # Map alias if defined
                key = alias_map.get(raw_key, raw_key)

                # Skip protected fields (id, accession_number, etc.)
                if key in protected_fields:
                    invalid_fields.append(raw_key)
                    continue

                # Column must exist in current order row
                if key not in order:
                    invalid_fields.append(raw_key)
                    continue

                # Capture requested status change for lifecycle handling
                if key == 'status' and isinstance(value, str):
                    requested_status = value.strip().upper()

                # Handle JSON columns
                if key in json_fields and value is not None:
                    update_clauses.append(f"{key} = %s")
                    params.append(Json(value))
                else:
                    update_clauses.append(f"{key} = %s")
                    params.append(value)

            # If there are invalid fields, reject with clear message
            if invalid_fields:
                # Build allowed_fields from current order keys minus protected
                allowed_fields = sorted(
                    [k for k in order.keys() if k not in protected_fields]
                )
                return jsonify({
                    "status": "error",
                    "message": "Some fields are not allowed or not recognized for update",
                    "invalid_fields": invalid_fields,
                    "allowed_fields": allowed_fields,
                    "hint": "Use canonical column names or supported aliases: "
                            "requested_procedure→procedure_name, "
                            "station_ae_title→ordering_station_aet, "
                            "scheduled_start_at→scheduled_at"
                }), 400

            if not update_clauses:
                return jsonify({
                    "status": "error",
                    "message": "No valid fields to update"
                }), 400

            # Apply lifecycle side effects based on status change
            actor = request.headers.get('X-User-ID') or request.headers.get('X-User-Name') \
                or request.headers.get('X-Username') or 'system'

            if requested_status:
                # Only if status actually changes
                if requested_status != old_status:
                    # Completed-state: set completed_at/by once
                    if is_completed_status(requested_status) and not order.get('completed_at'):
                        update_clauses.append("completed_at = CURRENT_TIMESTAMP")
                        update_clauses.append("completed_by = %s")
                        params.append(actor)
                    # Canceled/void/deleted-state: set cancel_at/by once
                    if is_canceled_status(requested_status) and not order.get('cancel_at'):
                        update_clauses.append("cancel_at = CURRENT_TIMESTAMP")
                        update_clauses.append("cancel_by = %s")
                        params.append(actor)

            # Always update updated_at
            update_clauses.append("updated_at = CURRENT_TIMESTAMP")

            params.append(str(order['id']))
            sql = f"""
                UPDATE orders
                SET {', '.join(update_clauses)}
                WHERE id = %s
            """
            cursor.execute(sql, params)

            # Audit log
            log_order_action(
                order['id'],
                order['order_number'],
                order['accession_number'],
                'ORDER_UPDATED',
                {"previous_status": order.get('status')},
                body,
                request.headers.get('X-User-ID', 'system'),
                request.remote_addr,
            )

            return jsonify({
                "status": "success",
                "message": "Order updated successfully",
                "order_id": str(order['id']),
                "accession_number": order['accession_number'],
            }), 200

    except Exception as e:
        logger.error(f"Error updating order: {str(e)}", exc_info=True)
        return jsonify({"status": "error", "message": str(e)}), 500

# -----------------------------------------------------------------------------
# ORDER FILES CRUD (metadata only, JSON via Gateway)
# -----------------------------------------------------------------------------

@app.route('/orders/<identifier>/files', methods=['GET'])
def get_order_files(identifier):
    """
    List files associated with an order.

    Identifier:
      - UUID id, atau
      - accession_number, atau
      - order_number.

    Hanya orders dengan status != 'DELETED'.
    Auth & permission:
      - Dihandle di API Gateway (order:read atau *).
    """
    try:
        with get_db_connection() as conn:
            oc = conn.cursor(cursor_factory=RealDictCursor)
            # Resolve order
            try:
                uuid_obj = uuid.UUID(identifier)
                oc.execute(
                    """
                    SELECT id, order_number, accession_number, patient_name,
                           modality, status, created_at
                    FROM orders
                    WHERE id = %s AND status != 'DELETED'
                    """,
                    (str(uuid_obj),),
                )
            except ValueError:
                oc.execute(
                    """
                    SELECT id, order_number, accession_number, patient_name,
                           modality, status, created_at
                    FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                      AND status != 'DELETED'
                    """,
                    (identifier, identifier),
                )

            order = oc.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            order_id = str(order["id"])
            order["id"] = order_id

            fc = conn.cursor(cursor_factory=RealDictCursor)
            fc.execute(
                """
                SELECT
                    id,
                    filename,
                    file_type,
                    category,
                    size_bytes,
                    storage_path,
                    checksum_sha256,
                    metadata,
                    created_at,
                    created_by,
                    source
                FROM order_files
                WHERE order_id = %s
                ORDER BY created_at ASC, id ASC
                """,
                (order_id,),
            )
            files = fc.fetchall() or []
            for f in files:
                f["id"] = str(f["id"])

            return jsonify({
                "status": "success",
                "order": order,
                "files": files,
            }), 200

    except Exception as e:
        logger.error(f"Error getting order files for {identifier}: {str(e)}", exc_info=True)
        return jsonify({
            "status": "error",
            "message": "Failed to get order files",
            "detail": str(e),
        }), 500


@app.route('/orders/<identifier>/files', methods=['POST'])
def add_order_file(identifier):
    """
    Attach a file to an order.

    Supports:
    - multipart/form-data:
        - file (required)
        - category (optional)
        - metadata (optional, JSON string)
    - application/json (backward-compatible metadata-only):
        - filename, file_type, etc.

    Auth & permission:
    - Enforced by API Gateway (order:create or * by default).
    """
    try:
        # 1) Resolve target order (shared for both modes)
        with get_db_connection() as conn:
            oc = conn.cursor(cursor_factory=RealDictCursor)
            try:
                uuid_obj = uuid.UUID(identifier)
                oc.execute(
                    """
                    SELECT id, accession_number
                    FROM orders
                    WHERE id = %s AND status != 'DELETED'
                    """,
                    (str(uuid_obj),),
                )
            except ValueError:
                oc.execute(
                    """
                    SELECT id, accession_number
                    FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                      AND status != 'DELETED'
                    """,
                    (identifier, identifier),
                )

            order = oc.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            order_id = str(order["id"])
            acc_no = order.get("accession_number")

        # 2) Resolve actor/source once (outside DB context)
        try:
            actor_info = resolve_request_actor()
        except Exception:
            actor_info = {}
        if not isinstance(actor_info, dict):
            actor_info = {}

        created_by = (
            actor_info.get("username")
            or actor_info.get("id")
            or request.headers.get("X-User-ID")
            or "system"
        )
        source = (
            request.headers.get("X-Order-Source")
            or actor_info.get("source")
            or "api"
        )

        ct = (request.headers.get("Content-Type") or "").lower()

        # 3) MULTIPART MODE: actual file upload
        if ct.startswith("multipart/form-data"):
            upload = request.files.get("file")
            if not upload:
                logger.warning("Multipart upload received without 'file' field")
                return jsonify({
                    "status": "error",
                    "message": "Missing file field in multipart/form-data (expected name='file')"
                }), 400

            # Optional fields from form
            category = (request.form.get("category") or "other").strip() or "other"
            raw_metadata = request.form.get("metadata")
            metadata = {}
            if raw_metadata:
                try:
                    metadata = json.loads(raw_metadata)
                    if not isinstance(metadata, dict):
                        metadata = {"_value": metadata}
                except Exception:
                    # Keep raw string if not valid JSON
                    metadata = {"_raw": raw_metadata}

            # Jika mimetype menunjukkan DICOM dan category masih generic, set ke 'dicom' untuk konsistensi
            try:
                if "dicom" in (file_type or "").lower() and category.lower() in ("other", "", "file", "image"):
                    logger.info(
                        f"[order-files] Auto-adjust category to 'dicom' for DICOM upload "
                        f"(was '{category}')"
                    )
                    category = "dicom"
            except Exception as cat_err:
                logger.warning(f"[order-files] Failed to normalize DICOM category: {cat_err}")

            # Prefer explicit filename from form if provided (as in some clients)
            form_filename = (request.form.get("filename") or "").strip()
            original_filename = form_filename or (upload.filename or "file")

            # Prefer explicit file_type from form; fall back to mimetype or safe default
            file_type = (
                (request.form.get("file_type") or "").strip()
                or upload.mimetype
                or "application/octet-stream"
            )

            # Normalize DICOM filename: ensure .dcm extension if detected as DICOM
            try:
                lower_name = (original_filename or "").lower()
                is_dicom_ext = lower_name.endswith(".dcm") or lower_name.endswith(".dicom")
                is_dicom_mime = "dicom" in (file_type or "").lower()
                form_category = (request.form.get("category") or "").strip().lower()
                is_dicom_category = form_category in ("dicom", "imaging", "image")  # heuristik ringan

                if (is_dicom_ext or is_dicom_mime or is_dicom_category) and not lower_name.endswith(".dcm"):
                    # Tambahkan .dcm jika belum ada suffix .dcm
                    original_filename = original_filename + ".dcm"
                    logger.info(
                        f"[order-files] Normalized DICOM filename to ensure .dcm extension: {original_filename}"
                    )
            except Exception as norm_err:
                logger.warning(f"[order-files] Failed to normalize DICOM filename: {norm_err}")

            # Optional: size_bytes hint (not required, we still compute actual size)
            try:
                hinted_size = int(request.form.get("size_bytes")) if request.form.get("size_bytes") else None
            except (TypeError, ValueError):
                hinted_size = None

            logger.info(
                f"[order-files] multipart upload: order_id={order_id}, "
                f"filename={original_filename!r}, file_type={file_type!r}, "
                f"category={category!r}, hinted_size={hinted_size}, "
                f"created_by={created_by}, source={source}"
            )

            # Generate file_id now so we can use it as filename on disk
            file_id = str(uuid.uuid4())

            # Build storage path: {ROOT}/{order_id}/{file_id}
            storage_root = ORDER_FILES_STORAGE_ROOT.rstrip("/")
            order_dir = os.path.join(storage_root, order_id)
            os.makedirs(order_dir, exist_ok=True)
            storage_path = os.path.join(order_dir, file_id)

            # Save file to disk and compute size/checksum
            import hashlib

            sha256 = hashlib.sha256()
            size_bytes = 0
            # Save streamed to avoid high memory use
            with open(storage_path, "wb") as f:
                # werkzeug FileStorage supports iterating via .stream
                chunk = upload.stream.read(8192)
                while chunk:
                    size_bytes += len(chunk)
                    sha256.update(chunk)
                    f.write(chunk)
                    chunk = upload.stream.read(8192)

            checksum_sha256 = sha256.hexdigest()

            # Insert metadata row
            with get_db_connection() as conn:
                fc = conn.cursor(cursor_factory=RealDictCursor)
                fc.execute(
                    """
                    INSERT INTO order_files (
                        id,
                        order_id,
                        accession_number,
                        filename,
                        file_type,
                        category,
                        size_bytes,
                        storage_path,
                        checksum_sha256,
                        metadata,
                        created_by,
                        source
                    )
                    VALUES (
                        %s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s
                    )
                    RETURNING
                        id,
                        filename,
                        file_type,
                        category,
                        size_bytes,
                        storage_path,
                        checksum_sha256,
                        metadata,
                        created_at,
                        created_by,
                        source
                    """,
                    (
                        file_id,
                        order_id,
                        acc_no,
                        original_filename,
                        file_type,
                        category,
                        size_bytes,
                        storage_path,
                        checksum_sha256,
                        Json(metadata),
                        created_by,
                        source,
                    ),
                )
                rec = fc.fetchone()
                rec["id"] = str(rec["id"])

            return jsonify({
                "status": "success",
                "file": rec
            }), 201

        # 4) JSON MODE: backward-compatible metadata-only
        body = request.get_json(silent=True) or {}

        filename = (body.get("filename") or "").strip()
        file_type = (body.get("file_type") or body.get("type") or "").strip()
        category = (body.get("category") or "other").strip() or "other"

        if not filename or not file_type:
            return jsonify({
                "status": "error",
                "message": "filename and file_type are required"
            }), 400

        size_bytes = body.get("size_bytes") or body.get("size")
        storage_path = body.get("storage_path") or body.get("path")
        checksum_sha256 = body.get("checksum_sha256") or body.get("checksum")
        metadata = body.get("metadata") or {}

        with get_db_connection() as conn:
            fc = conn.cursor(cursor_factory=RealDictCursor)
            fc.execute(
                """
                INSERT INTO order_files (
                    order_id,
                    accession_number,
                    filename,
                    file_type,
                    category,
                    size_bytes,
                    storage_path,
                    checksum_sha256,
                    metadata,
                    created_by,
                    source
                )
                VALUES (
                    %s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s
                )
                RETURNING
                    id,
                    filename,
                    file_type,
                    category,
                    size_bytes,
                    storage_path,
                    checksum_sha256,
                    metadata,
                    created_at,
                    created_by,
                    source
                """,
                (
                    order_id,
                    acc_no,
                    filename,
                    file_type,
                    category,
                    size_bytes,
                    storage_path,
                    checksum_sha256,
                    Json(metadata),
                    created_by,
                    source,
                ),
            )
            rec = fc.fetchone()
            rec["id"] = str(rec["id"])

        rec["id"] = str(rec["id"])
        return jsonify({
            "status": "success",
            "file": rec
        }), 201

    except Exception as e:
        logger.error(f"Error adding file for order {identifier}: {str(e)}", exc_info=True)
        return jsonify({
            "status": "error",
            "message": "Failed to add order file",
            "detail": str(e)
        }), 500


@app.route('/orders/<identifier>/files/<file_id>', methods=['DELETE'])
def delete_order_file(identifier, file_id):
    """
    Delete a file metadata record from an order.

    NOTE:
    - Auth & permission di-enforce oleh API Gateway:
        - DELETE /orders/<id>/files/<file_id> -> requires order:delete atau *
    - Hanya menghapus metadata di order_files, tidak otomatis menghapus file fisik.
    """
    try:
        with get_db_connection() as conn:
            oc = conn.cursor(cursor_factory=RealDictCursor)

            # 1) Resolve order
            try:
                uuid_obj = uuid.UUID(identifier)
                oc.execute(
                    """
                    SELECT id
                    FROM orders
                    WHERE id = %s AND status != 'DELETED'
                    """,
                    (str(uuid_obj),),
                )
            except ValueError:
                oc.execute(
                    """
                    SELECT id
                    FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                      AND status != 'DELETED'
                    """,
                    (identifier, identifier),
                )

            order = oc.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            order_id = str(order["id"])

            # 2) Ensure file belongs to this order and delete
            fc = conn.cursor(cursor_factory=RealDictCursor)
            try:
                file_uuid = uuid.UUID(file_id)
            except ValueError:
                return jsonify({"status": "error", "message": "Invalid file_id"}), 400

            fc.execute(
                """
                SELECT id
                FROM order_files
                WHERE id = %s AND order_id = %s
                """,
                (str(file_uuid), order_id),
            )
            existing = fc.fetchone()
            if not existing:
                return jsonify({
                    "status": "error",
                    "message": "File not found for this order"
                }), 404

            fc.execute(
                "DELETE FROM order_files WHERE id = %s",
                (str(file_uuid),),
            )

            return jsonify({
                "status": "success",
                "message": "Order file deleted",
                "file_id": str(file_uuid),
                "order_id": order_id
            }), 200

    except Exception as e:
        logger.error(f"Error deleting file {file_id} for order {identifier}: {str(e)}", exc_info=True)
        return jsonify({
            "status": "error",
            "message": "Failed to delete order file",
            "detail": str(e)
        }), 500


@app.route('/orders/<identifier>/files/<file_id>/content', methods=['GET'])
def download_order_file(identifier, file_id):
    """
    Download/stream the physical file content for a specific order file.

    Identifier:
      - UUID id, accession_number, or order_number for the order.

    Behavior:
      - Validates that the order exists and is not DELETED.
      - Validates that the file_id is a valid UUID and belongs to that order.
      - Reads file from storage_path on disk.
      - Returns file bytes with appropriate Content-Type and filename.

    Auth:
      - Enforced by API Gateway (order:read or *).
    """
    try:
        # 1) Resolve order
        with get_db_connection() as conn:
            oc = conn.cursor(cursor_factory=RealDictCursor)
            try:
                uuid_obj = uuid.UUID(identifier)
                oc.execute(
                    """
                    SELECT id
                    FROM orders
                    WHERE id = %s AND status != 'DELETED'
                    """,
                    (str(uuid_obj),),
                )
            except ValueError:
                oc.execute(
                    """
                    SELECT id
                    FROM orders
                    WHERE (accession_number = %s OR order_number = %s)
                      AND status != 'DELETED'
                    """,
                    (identifier, identifier),
                )

            order = oc.fetchone()
            if not order:
                return jsonify({"status": "error", "message": "Order not found"}), 404

            order_id = str(order["id"])

            # 2) Validate file_id and load file metadata
            try:
                file_uuid = uuid.UUID(file_id)
            except ValueError:
                return jsonify({"status": "error", "message": "Invalid file_id"}), 400

            fc = conn.cursor(cursor_factory=RealDictCursor)
            fc.execute(
                """
                SELECT
                    id,
                    filename,
                    file_type,
                    storage_path,
                    size_bytes
                FROM order_files
                WHERE id = %s AND order_id = %s
                """,
                (str(file_uuid), order_id),
            )
            f = fc.fetchone()
            if not f:
                return jsonify({
                    "status": "error",
                    "message": "File not found for this order"
                }), 404

        storage_path = f.get("storage_path")
        if not storage_path:
            return jsonify({
                "status": "error",
                "message": "No storage_path recorded for this file (metadata-only entry)"
            }), 404

        # 3) Read file from disk and stream to client
        if not os.path.isfile(storage_path):
            return jsonify({
                "status": "error",
                "message": "File not found on server storage"
            }), 404

        filename = f.get("filename") or file_id
        mimetype = f.get("file_type") or "application/octet-stream"

        # Use send_file to stream content; as_attachment=False for inline display by default.
        # Clients can inspect headers to decide download vs preview.
        return send_file(
            storage_path,
            mimetype=mimetype,
            as_attachment=False,
            download_name=filename
        )

    except Exception as e:
        logger.error(f"Error downloading file {file_id} for order {identifier}: {str(e)}", exc_info=True)
        return jsonify({
            "status": "error",
            "message": "Failed to download order file",
            "detail": str(e)
        }), 500


if __name__ == '__main__':
    # Ensure log directory exists
    os.makedirs('/var/log/orders', exist_ok=True)

    try:
        # Wait until database is reachable
        wait_for_database()
    except Exception as e:
        logger.critical(f"FATAL: Database readiness check failed: {e}", exc_info=True)
        sys.exit(1)

    try:
        # Run migrations / schema alignment
        init_database()
        logger.info("Order management service initialized")
    except Exception as e:
        logger.critical(f"FATAL: Database initialization failed: {e}", exc_info=True)
        logger.critical("The service will now exit.")
        sys.exit(1)

    logger.info("=" * 80)
    logger.info("Order Management Service starting...")
    logger.info("Features:")
    logger.info("  - Auto Accession Number generation")
    logger.info("  - Order data persistence")
    logger.info("  - SATUSEHAT integration")
    logger.info("  - MWL Worklist creation")
    logger.info("  - Complete flow automation")
    logger.info("  - Order files upload/download (DICOM, docs, etc.)")
    logger.info("=" * 80)

    app.run(host='0.0.0.0', port=8001, debug=False)
