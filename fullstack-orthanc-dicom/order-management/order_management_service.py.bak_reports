# Modify existing endpoint to simple version
@app.route('/orders/all', methods=['GET'])
def list_all_orders_simple():
    try:
        with get_db_connection() as conn:
            cursor = conn.cursor(cursor_factory=RealDictCursor)
            query = """
                SELECT 
                    id,
                    order_number,
                    accession_number,
                    patient_name,
                    modality,
                    order_source,
                    status,
                    created_at,
                    completed_at,
                    completed_by,
                    cancel_at,
                    cancel_by
                FROM orders 
                WHERE status != 'DELETED'
            """
            cursor.execute(query)
            orders = cursor.fetchall()
            
            # Convert UUID to string
            for order in orders:
                order['id'] = str(order['id'])
            
            return jsonify({
                "status": "success",
                "orders": orders,
                "count": len(orders)
            }), 200
            
    except Exception as e:
        logger.error(f"Error listing all orders: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

