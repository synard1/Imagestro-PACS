    "@tiptap/starter-kit": "^3.10.7",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.6.0",
    "boneyard-js": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dcmjs": "^0.45.0",
    "dicom-parser": "^1.8.21",
    "dompurify": "^3.3.1",
    "express": "^4.18.2",
