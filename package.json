{
  "name": "mwl-pacs-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run tests/ci/baseline.test.js",
    "test:coverage": "vitest run --coverage",
    "ci:frontend": "npm run build && npm run test:ci",
    "ci:python-syntax": "python -m compileall -q api-gateway pacs-service master-data-service order-management",
    "ci:logs-bindings": "node cloudflare/shared/logs-db/scripts/check-log-bindings.mjs",
    "ci:logs-migration": "node cloudflare/shared/logs-db/scripts/ci-logs-migration-dryrun.mjs",
    "ci": "npm run ci:frontend && npm run ci:python-syntax && npm run ci:logs-bindings && npm run ci:logs-migration",
    "server": "node start-server.js",
    "server:test": "node test-server.js",
    "server:direct": "node server-example.js",
    "server:upload": "node server-with-upload.js",
    "clear-cache": "node clear-cache.js",
    "dev:fresh": "npm run clear-cache && npm run dev",
    "force-sw-update": "node force-sw-update.js",
    "test-pwa-update": "npm run force-sw-update && echo 'Open test-pwa-update.html in browser to test'"
  },
  "dependencies": {
    "@cornerstonejs/core": "^1.80.4",
