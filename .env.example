# MWL-PACS-UI Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# Backend API Configuration
# ============================================================================

# Main API Backend URL (FastAPI Gateway)
# Development: http://localhost:8003
# Production: https://api.yourdomain.com
VITE_MAIN_API_BACKEND_URL=http://localhost:8003

# PACS API Backend URL (DICOM/PACS Services)
# Development: http://103.42.117.19:8888
# Production: https://pacs-api.yourdomain.com
VITE_MAIN_PACS_API_BACKEND_URL=http://103.42.117.19:8888

# ============================================================================
# Legacy Environment Variables (Deprecated - Use above instead)
# ============================================================================

# Legacy API Base URL (being phased out)
VITE_API_BASE_URL=http://localhost:8003

# Legacy PACS API URL (being phased out)
VITE_PACS_API_URL=http://localhost:8003

# ============================================================================
# Authentication Configuration
# ============================================================================

# Enable local mock authentication for development
# Set to 'true' for local development without backend
# Set to 'false' for production with real backend authentication
VITE_ENABLE_LOCAL_AUTH=false

# ============================================================================
# Application Configuration
# ============================================================================

# Application Environment
# Options: development, staging, production
VITE_APP_ENV=development

# Enable debug mode
VITE_DEBUG=false

# ============================================================================
# CORS Configuration
# ============================================================================

# Enable CORS proxy in development
VITE_ENABLE_CORS_PROXY=false

# ============================================================================
# External Integrations
# ============================================================================

# SIMRS Khanza API URL (if using external SIMRS integration)
VITE_KHANZA_API_URL=http://localhost:3007

# SATUSEHAT API Configuration
VITE_SATUSEHAT_ENV=sandbox
VITE_SATUSEHAT_CLIENT_ID=
VITE_SATUSEHAT_CLIENT_SECRET=
VITE_SATUSEHAT_ORGANIZATION_ID=

# ============================================================================
# Feature Flags
# ============================================================================

# Enable DICOM viewer
VITE_ENABLE_DICOM_VIEWER=true

# Enable SIMRS integration
VITE_ENABLE_SIMRS=true

# Enable SATUSEHAT integration
VITE_ENABLE_SATUSEHAT=false

# ============================================================================
# Performance Configuration
# ============================================================================

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Enable lazy loading
VITE_ENABLE_LAZY_LOADING=true

# ============================================================================
# Security Configuration
# ============================================================================

# CSRF Token Header Name
VITE_CSRF_HEADER=X-CSRF-Token

# Session timeout in minutes
VITE_SESSION_TIMEOUT=30

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info

# Enable console logs in production
VITE_ENABLE_CONSOLE_LOGS=false

# ============================================================================
# PWA Configuration (Environment Override)
# ============================================================================

# Master PWA Control - Set to 'false' to completely disable PWA system-wide
# This overrides all user settings and prevents PWA from being enabled
# Use this for emergency situations or when PWA causes issues
VITE_PWA_FORCE_DISABLED=false

# PWA Features Control - Set to 'false' to disable specific features system-wide
VITE_PWA_ALLOW_OFFLINE_MODE=true
VITE_PWA_ALLOW_CACHING=true
VITE_PWA_ALLOW_INSTALL_PROMPTS=true
VITE_PWA_ALLOW_UPDATE_NOTIFICATIONS=true
VITE_PWA_ALLOW_BACKGROUND_SYNC=true
VITE_PWA_ALLOW_PUSH_NOTIFICATIONS=false

# PWA Cache Strategy Override
# Options: 'intelligent', 'aggressive', 'minimal', 'disabled'
# Set to override user's cache strategy choice (leave empty to allow user choice)
VITE_PWA_FORCE_CACHE_STRATEGY=

# PWA Emergency Mode - Set to 'true' to disable all PWA and clear caches
# Use this if PWA is causing application access issues
VITE_PWA_EMERGENCY_MODE=false

# PWA Development Mode - Enhanced logging and reduced cache limits for development
VITE_PWA_DEVELOPMENT_MODE=false

# ============================================================================
# Cache Manager UI Configuration
# ============================================================================

# Show/Hide Cache Manager Window
# Set to 'false' to hide the cache manager window/widget completely
# Useful for production environments or when cache manager is not needed
VITE_SHOW_CACHE_MANAGER=true

# Cache Manager Position
# Options: 'bottom-right', 'bottom-left', 'top-right', 'top-left', 'hidden'
# Controls where the cache manager window appears on screen
VITE_CACHE_MANAGER_POSITION=bottom-right

# Cache Manager Auto Hide
# Set to 'true' to auto-hide cache manager after specified time
# Helps reduce UI clutter while keeping functionality available
VITE_CACHE_MANAGER_AUTO_HIDE=false

# Cache Manager Auto Hide Delay (milliseconds)
# Time before auto-hiding cache manager (only if auto-hide is enabled)
# Default: 10 seconds (10000ms)
VITE_CACHE_MANAGER_AUTO_HIDE_DELAY=10000

# Cache Manager Minimize on Start
# Set to 'true' to start cache manager in minimized state
# User can still expand it when needed
VITE_CACHE_MANAGER_START_MINIMIZED=false

# Cache Manager Development Only
# Set to 'true' to show cache manager only in development mode
# Automatically hides in production builds
VITE_CACHE_MANAGER_DEV_ONLY=true

VITE_SHOW_CACHE_MANAGER=true
